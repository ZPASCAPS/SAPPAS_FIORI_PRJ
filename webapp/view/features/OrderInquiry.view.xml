<!--
  OrderInquiry.view.xml  (A공간 — 문서 조회)
  OData: Tracker + OrderSummary(SO) + SD/MM/PP/FI DocSummary
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.OrderInquiry"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    height="100%"
    width="100%">

    <VBox class="nxSpaceCard nxSpaceCardA" height="100%" width="100%" renderType="Bare">
        <HBox class="nxSpaceCardHeader" alignItems="Center" width="100%">
            <Title text="{i18n>documentInquiryTitle}" level="H4" class="nxSpaceCardTitle" />
        </HBox>

        <VBox class="nxSpaceCardBody nxSpaceCardBodyA" width="100%" renderType="Bare">
            <Select
                id="docTypeSelect"
                selectedKey="SO"
                width="100%"
                change=".onDocTypeChange"
                class="nxSpaceDocTypeSelect">
                <core:Item key="SO" text="판매오더 (SO)" />
                <core:Item key="PlannedOrder" text="계획오더 (PlannedOrder)" />
                <core:Item key="PR" text="구매요청 (PR)" />
                <core:Item key="PO" text="구매오더 (PO)" />
                <core:Item key="POMigo" text="원자재입고 MIGO (POMigo)" />
                <core:Item key="Production" text="생산오더 (Production)" />
                <core:Item key="ProdMigo" text="완제품입고 MIGO (ProdMigo)" />
                <core:Item key="DN" text="출하 (DN)" />
                <core:Item key="BL" text="청구 (BL)" />
                <core:Item key="FI" text="회계전표 (FI)" />
                <core:Item key="Clearing" text="입금전기 (Clearing)" />
            </Select>

            <SearchField
                id="docNumberInput"
                placeholder="판매오더 번호 검색"
                width="100%"
                class="nxSpaceSearch"
                search=".onSearchOrder" />
            <Button
                text="{i18n>documentInquirySearchBtn}"
                type="Emphasized"
                press=".onSearchOrder"
                width="100%"
                class="nxSpaceSearchBtn" />

            <VBox
                class="nxOrderResultPanel"
                width="100%"
                renderType="Bare"
                visible="{dashboard>/spaces/orderInquiry/visible}">
                <HBox class="nxOrderResultHeader" alignItems="Center" renderType="Bare">
                    <Text text="📄" class="nxOrderIcon" />
                    <Text text="{dashboard>/spaces/orderInquiry/headerDisplay}" class="nxOrderNumber" />
                </HBox>

                <VBox class="nxOrderStageBlock" renderType="Bare" width="100%">
                    <Text text="{i18n>documentInquiryCurrentStage}" class="nxOrderLabel" />
                    <Text text="{dashboard>/spaces/orderInquiry/stageLabel}" class="nxOrderStageText" />
                    <VBox class="nxOrderProgressBar" renderType="Bare" width="100%">
                        <HBox
                            id="orderProgressFill"
                            class="nxOrderProgressFill"
                            width="{= ${dashboard>/spaces/orderInquiry/progressPercent} + '%' }"
                            height="0.75rem"
                            renderType="Bare" />
                        <Text text="i" class="nxOrderProgressInfo" />
                    </VBox>
                </VBox>

                <VBox class="nxOrderDetailList" width="100%" renderType="Bare">
                    <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                        <Text text="{i18n>documentInquiryLinkedSO}" class="nxOrderDetailLabel" />
                        <Text text="{dashboard>/spaces/orderInquiry/linkedSalesOrder}" class="nxOrderDetailValue" />
                    </HBox>

                    <!-- SO -->
                    <VBox visible="{= ${dashboard>/spaces/orderInquiry/docType} === 'SO' }" renderType="Bare" width="100%">
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryEstimatedDays}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/estimatedDays}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryCustomer}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/customer}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Start" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryProduct}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/material}" class="nxOrderDetailValue nxOrderProductName" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryQuantity}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/quantity}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryAmount}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/amount}" class="nxOrderDetailValue nxOrderAmount" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryCreationDate}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/creationDate}" class="nxOrderDetailValue" />
                        </HBox>
                    </VBox>

                    <!-- PlannedOrder -->
