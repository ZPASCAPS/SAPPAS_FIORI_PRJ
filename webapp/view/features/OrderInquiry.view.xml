                    <VBox visible="{= ${dashboard>/spaces/orderInquiry/docType} === 'Clearing' }" renderType="Bare" width="100%">
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>documentInquiryCustomer}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/customerName}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>docInquiryClearingAmount}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/amount}" class="nxOrderDetailValue nxOrderAmount" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>docInquiryClearingDate}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/clearingDate}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>docInquiryPaymentMethod}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/paymentMethod}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>docInquiryClearingDoc}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/clearingDocument}" class="nxOrderDetailValue" />
                        </HBox>
                        <HBox class="nxOrderDetailRow" alignItems="Center" justifyContent="SpaceBetween" width="100%" renderType="Bare">
                            <Text text="{i18n>docInquiryRefBilling}" class="nxOrderDetailLabel" />
                            <Text text="{dashboard>/spaces/orderInquiry/display/refBilling}" class="nxOrderDetailValue" />
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <VBox
                class="nxSpaceInnerEmpty nxSpaceInnerEmptyA"
                width="100%"
                visible="{= !${dashboard>/spaces/orderInquiry/visible} }" />
        </VBox>
    </VBox>
</mvc:View>
