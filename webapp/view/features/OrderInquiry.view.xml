<!--
  OrderInquiry.view.xml  (A공간 — 오더 조회)

  View: com.capstone.dashboard.fioridashboard.view.features.OrderInquiry
  Controller: com.capstone.dashboard.fioridashboard.controller.features.OrderInquiry

  역할:
  - 메인 대시보드 왼쪽(A) 영역. 오더 조회 UI를 단계적으로 구현한다.
  - 공통 dashboard JSONModel은 Main.controller.js에서 제공한다.

  대시보드 구조:
  Main → DashboardMain → DashboardCanvas → OrderInquiry (A공간)

  협업:
  - 오더 조회 UI·이벤트 → 이 View + OrderInquiry.controller.js
  - 공통 데이터 필드 → Main.controller.js (dashboard/spaces/orderInquiry)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.OrderInquiry"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    height="100%"
    width="100%">

    <VBox class="nxSpaceCard nxSpaceCardA" height="100%" width="100%" renderType="Bare">
        <HBox class="nxSpaceCardHeader" alignItems="Center" width="100%">
            <Title text="오더 조회" level="H4" class="nxSpaceCardTitle" />
        </HBox>

        <VBox class="nxSpaceCardBody nxSpaceCardBodyA" width="100%">
            <SearchField
                id="salesOrderInput" 
                placeholder="오더 번호 검색 (예: 320)"
                width="100%"
                class="nxSpaceSearch" />
            <Button
                text="조회"
                press=".onSearchOrder" 
                type="Emphasized"
                width="100%"
                class="nxSpaceSearchBtn" />
            <VBox class="nxOrderResultPanel" width="100%" renderType="Bare">
                <HBox class="nxOrderResultHeader" alignItems="Center" renderType="Bare">
                    <core:Icon src="sap-icon://order-status" class="nxOrderIcon" size="1.25rem" />
                    <Text text="5000000010" class="nxOrderNumber" />
                </HBox>

                <VBox class="nxOrderStageBlock" width="100%" renderType="Bare">
                    <Text text="현재 단계" class="nxOrderLabel" />
                    <Text text="4 / 9 · Purchase Order" class="nxOrderStageText" />
                    <HBox class="nxOrderProgressBar" alignItems="Center" renderType="Bare">
                        <VBox class="nxOrderProgressFill" />
                        <VBox class="nxOrderProgressDot" />
                        <Text text="i" class="nxOrderProgressInfo" />
                    </HBox>
                </VBox>

                <VBox class="nxOrderDetailList" width="100%" renderType="Bare">
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="예상 소요" class="nxOrderDetailLabel" />
                        <Text text="12일 (예상)" class="nxOrderDetailValue" />
                    </HBox>
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="고객" class="nxOrderDetailLabel" />
                        <Text text="(주) 한국페인트" class="nxOrderDetailValue" />
                    </HBox>
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="제품명" class="nxOrderDetailLabel" />
                        <Text text="UP-F-PNT-001 / 파스칼 프리미엄 페인트" class="nxOrderDetailValue nxOrderProductName" />
                    </HBox>
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="수량" class="nxOrderDetailLabel" />
                        <Text text="100 EA" class="nxOrderDetailValue" />
                    </HBox>
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="금액" class="nxOrderDetailLabel" />
                        <Text text="₩ 128,500,000" class="nxOrderDetailValue nxOrderAmount" />
                    </HBox>
                    <HBox class="nxOrderDetailRow" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                        <Text text="생성일" class="nxOrderDetailLabel" />
                        <Text text="2025.05.18" class="nxOrderDetailValue" />
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
