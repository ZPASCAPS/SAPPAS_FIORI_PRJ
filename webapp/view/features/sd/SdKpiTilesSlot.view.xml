<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.sd.SdKpiTilesSlot"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%"
    height="100%">

    <HBox class="nxSdDashKpiRow" width="100%" height="100%" renderType="Bare" alignItems="Stretch">
        <VBox class="nxSdDashKpiCard" renderType="Bare">
            <HBox class="nxSdDashKpiTopRow" width="100%" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                <Text text="{sdKpi>/seasonAchievement/label}" class="nxSdDashKpiLabel" />
                <VBox renderType="Bare" class="nxSdDashKpiIconWrap">
                    <core:Icon src="{sdKpi>/seasonAchievement/icon}" size="2rem" color="#7C3AED" />
                </VBox>
            </HBox>
            <VBox class="nxSdDashKpiBottom" renderType="Bare">
                <HBox alignItems="Center" renderType="Bare" class="nxSdDashKpiValueRow">
                    <Text text="{sdKpi>/seasonAchievement/valueText}" class="nxSdDashKpiValue" />
                </HBox>
                <Text text="{sdKpi>/seasonAchievement/footnote}" class="nxSdDashKpiFootnote" />
            </VBox>
        </VBox>

        <VBox class="nxSdDashKpiCard" renderType="Bare">
            <HBox class="nxSdDashKpiTopRow" width="100%" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                <Text text="{sdKpi>/returnAcceptanceRate/label}" class="nxSdDashKpiLabel" />
                <VBox renderType="Bare" class="nxSdDashKpiIconWrap">
                    <core:Icon src="{sdKpi>/returnAcceptanceRate/icon}" size="2rem" color="#7C3AED" />
                </VBox>
            </HBox>
            <VBox class="nxSdDashKpiBottom" renderType="Bare">
                <HBox alignItems="Center" renderType="Bare" class="nxSdDashKpiValueRow">
                    <Text text="{sdKpi>/returnAcceptanceRate/valueText}" class="nxSdDashKpiValue" />
                    <Text
                        text="{sdKpi>/returnAcceptanceRate/trendPillText}"
                        visible="{= !!${sdKpi>/returnAcceptanceRate/trendPillText} }"
                        class="{= 'nxSdDashPill ' + ${sdKpi>/returnAcceptanceRate/trendPillClass} }" />
                </HBox>
                <Text text="{sdKpi>/returnAcceptanceRate/footnote}" class="nxSdDashKpiFootnote" />
            </VBox>
        </VBox>

        <VBox id="sdCreditExceedCard" class="nxSdDashKpiCard nxSdDashKpiCard--clickable" renderType="Bare">
            <HBox class="nxSdDashKpiTopRow" width="100%" justifyContent="SpaceBetween" alignItems="Start" renderType="Bare">
                <Text text="{sdKpi>/creditExceed/label}" class="nxSdDashKpiLabel" />
                <VBox renderType="Bare" class="nxSdDashKpiIconWrap">
                    <core:Icon src="{sdKpi>/creditExceed/icon}" size="2rem" color="#7C3AED" />
                </VBox>
            </HBox>
            <VBox class="nxSdDashKpiBottom" renderType="Bare">
                <HBox alignItems="Center" renderType="Bare" class="nxSdDashKpiValueRow">
                    <Text text="{sdKpi>/creditExceed/valueText}" class="nxSdDashKpiValue" />
                    <Text text="{sdKpi>/creditExceed/valueSuffix}" class="nxSdDashKpiValueUnit" />
                    <Text text="{sdKpi>/creditExceed/trendPillText}" class="{= 'nxSdDashPill ' + ${sdKpi>/creditExceed/trendPillClass} }" />
                </HBox>
                <Text text="{sdKpi>/creditExceed/footnote}" class="nxSdDashKpiFootnote" />
            </VBox>
        </VBox>
    </HBox>
</mvc:View>