<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.ModuleSideNav"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="nxSidebar" width="15.5rem">
        <VBox class="nxBrandBar">
            <HBox class="nxBrandMark" alignItems="Center" justifyContent="Center" width="100%">
                <Image
                    src="images/pascal-logo.png"
                    densityAware="false"
                    class="nxBrandWordmark"
                    alt="Pascal" />
            </HBox>
        </VBox>

        <ScrollContainer vertical="true" horizontal="false" height="100%" class="nxSideScroll">
            <VBox class="nxSideNav">
                <Button
                    id="navDashboardHero"
                    text="Dashboard"
                    icon="sap-icon://bbyd-dashboard"
                    type="Emphasized"
                    iconFirst="true"
                    class="nxDashHero"
                    width="auto"
                    press=".onDashboardNav" />

                <VBox class="nxNavDivider" />

                <Text text="Main" class="nxNavSectionLabel" />
                <List
                    id="mainNavList"
                    mode="SingleSelectMaster"
                    includeItemInSelection="true"
                    selectionChange=".onMainNavSelect"
                    class="nxNavList">
                    <items>
                        <StandardListItem title="Worklist" icon="sap-icon://checklist">
                            <customData><core:CustomData key="navKey" value="WORKLIST" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Alerts" icon="sap-icon://alert">
                            <customData><core:CustomData key="navKey" value="ALERTS" /></customData>
                        </StandardListItem>
                    </items>
                </List>

                <VBox class="nxNavDivider" />

                <Text text="Serve" class="nxNavSectionLabel" />
                <List
                    id="serveNavList"
                    mode="SingleSelectMaster"
                    includeItemInSelection="true"
                    selectionChange=".onServeNavSelect"
                    class="nxNavList">
                    <items>
                        <StandardListItem title="SD Sales" icon="sap-icon://sales-order">
                            <customData><core:CustomData key="navKey" value="SD_SALES" /></customData>
                        </StandardListItem>
                        <StandardListItem title="MM Materials" icon="sap-icon://product">
                            <customData><core:CustomData key="navKey" value="MM_MATERIALS" /></customData>
                        </StandardListItem>
                        <StandardListItem title="PP Production" icon="sap-icon://factory">
                            <customData><core:CustomData key="navKey" value="PP_PRODUCTION" /></customData>
                        </StandardListItem>
                        <StandardListItem title="FI/CO Finance" icon="sap-icon://money-bills">
                            <customData><core:CustomData key="navKey" value="FI_CO_FINANCE" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Stock Monitor" icon="sap-icon://inventory">
                            <customData><core:CustomData key="navKey" value="STOCK_MONITOR" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Master Data Check" icon="sap-icon://validate">
                            <customData><core:CustomData key="navKey" value="MASTER_DATA_CHECK" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Report Center" icon="sap-icon://business-objects-experience">
                            <customData><core:CustomData key="navKey" value="REPORT_CENTER" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Document Flow" icon="sap-icon://process">
                            <customData><core:CustomData key="navKey" value="DOCUMENT_FLOW" /></customData>
                        </StandardListItem>
                    </items>
                </List>

                <VBox class="nxNavDivider" />

                <Text text="Support" class="nxNavSectionLabel" />
                <List
                    id="supportNavList"
                    mode="SingleSelectMaster"
                    includeItemInSelection="true"
                    selectionChange=".onSupportNavSelect"
                    class="nxNavList">
                    <items>
                        <StandardListItem title="T-code Guide" icon="sap-icon://syntax">
                            <customData><core:CustomData key="navKey" value="TCODE_GUIDE" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Error Helper" icon="sap-icon://message-error">
                            <customData><core:CustomData key="navKey" value="ERROR_HELPER" /></customData>
                        </StandardListItem>
                        <StandardListItem title="OData Status" icon="sap-icon://connected">
                            <customData><core:CustomData key="navKey" value="ODATA_STATUS" /></customData>
                        </StandardListItem>
                        <StandardListItem title="System Log" icon="sap-icon://document-text">
                            <customData><core:CustomData key="navKey" value="SYSTEM_LOG" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Settings" icon="sap-icon://action-settings">
                            <customData><core:CustomData key="navKey" value="SETTINGS" /></customData>
                        </StandardListItem>
                    </items>
                </List>
            </VBox>
        </ScrollContainer>

        <VBox class="nxSideFooter">
            <HBox alignItems="Center" class="nxTeamBox">
                <core:Icon src="sap-icon://group" size="1rem" color="#0070F2" class="sapUiTinyMarginEnd" />
                <VBox>
                    <Label text="Team" class="nxTeamLabel" />
                    <Text text="pas" class="nxTeamValue" />
                </VBox>
            </HBox>
            <Text text="© 2026 Uniqlo SAP Dashboard" class="nxCopyright" />
        </VBox>
    </VBox>
</mvc:View>
