<!--
  FiAccountsPayable.view.xml — FI Accounts Payable (OData 미연결 시 Empty State)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.FiAccountsPayable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxFiAccountsPayable fiCockpitPage" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/fiAccountsPayable/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/fiAccountsPayable/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <BusyIndicator visible="{dashboard>/fiAccountsPayable/loading}" class="nxFiAccountsPayableBusy" />

        <VBox visible="{= !${dashboard>/fiAccountsPayable/loading} }" width="100%" renderType="Bare" class="nxFiAccountsPayableBody">
            <VBox class="fiFeatureHero fiHeroAccountsPayable fiHeroCard" width="100%">
                <HBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="fiHeroCardHead">
                    <VBox class="fiHeroContent">
                        <Title text="Accounts Payable" level="H2" class="fiHeroTitle" />
                        <Text
                            text="구매 및 입고 이후 발생한 미지급금과 지급 상태를 확인하는 화면입니다."
                            class="fiHeroDescription" />
                    </VBox>
                    <HBox alignItems="Center" class="fiHeroActions">
                        <HBox alignItems="Center" class="fiHeroActionsBox">
                            <Button
                                id="fiAccountsPayableContentFilterBtn"
                                text="조회/필터"
                                icon="sap-icon://filter"
                                type="Transparent"
                                press=".onToolbarFilterOpen"
                                class="fiFilterButton" />
                        </HBox>
                    </HBox>
                </HBox>
            </VBox>

            <MessageStrip
                text="MM Purchasing / Goods Movement 이후 FI로 이어지는 미지급금 흐름을 확인하는 영역입니다."
                type="Information"
                showIcon="true"
                class="sapUiSmallMarginBottom fiContextStrip" />

            <HBox class="nxFiMasterDetail" width="100%" renderType="Bare">
                <VBox class="nxFiListPane" renderType="Bare">
                    <VBox class="nxFiCard nxFiListCard">
                        <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="{dashboard>/fiAccountsPayable/listTitle}" level="H5" />
                                <Text text="{dashboard>/fiAccountsPayable/listSubtitle}" class="nxFiCardSub" />
                            </VBox>
                            <VBox class="nxFiCardIconWrap nxFiCardIconWrap--payable">
                                <core:Icon src="sap-icon://money-bills" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>
                        <VBox
                            visible="{= !${dashboard>/fiAccountsPayable/odataConnected} }"
                            class="fiEmptyState"
                            alignItems="Center"
                            justifyContent="Center">
                            <core:Icon src="sap-icon://database" size="2rem" color="#94A3B8" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/fiAccountsPayable/emptyMessage}" class="fiEmptyStateTitle" />
                            <Text text="{dashboard>/fiAccountsPayable/emptyHint}" class="fiEmptyStateHint" />
                        </VBox>
                        <List
                            visible="{dashboard>/fiAccountsPayable/odataConnected}"
                            items="{fiAP>/Z_C_FI_AP}"
                            growing="true"
                            growingThreshold="20"
                            noDataText="데이터 없음"
                            width="100%">
                            <items>
                                <StandardListItem type="Active" />
                            </items>
                        </List>
                    </VBox>
                </VBox>

                <VBox class="nxFiDetailPane" renderType="Bare">
                    <VBox class="nxFiCard nxFiDetailCard">
                        <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Payable Detail" level="H5" />
                                <Text text="선택 미지급금 상세 정보" class="nxFiCardSub" />
                            </VBox>
                            <VBox class="nxFiCardIconWrap nxFiCardIconWrap--detail">
                                <core:Icon src="sap-icon://payment-approval" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>
                        <VBox
                            visible="{= !${dashboard>/fiAccountsPayable/detail/hasSelection} }"
                            class="fiEmptyState"
                            alignItems="Center"
                            justifyContent="Center">
                            <core:Icon src="sap-icon://cursor" size="2.25rem" color="#9CA3AF" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/fiAccountsPayable/detail/emptyMessage}" class="fiEmptyStateTitle" />
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</mvc:View>
