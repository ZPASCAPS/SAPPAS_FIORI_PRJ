<!--
  FiGeneralLedger.view.xml ??FI General Ledger (Z_C_FI_GL CDS OData)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.fi.FiGeneralLedger"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxFiGeneralLedger fiCockpitPage" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/fiGeneralLedger/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/fiGeneralLedger/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <VBox width="100%" renderType="Bare" class="nxFiGeneralLedgerBody">
            <VBox class="fiFeatureHero fiHeroGeneralLedger fiHeroCard" width="100%">
                <HBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="fiHeroCardHead">
                    <VBox class="fiHeroContent">
                        <Title text="General Ledger" level="H2" class="fiHeroTitle" />
                        <Text
                            text="Ļ│äņĀĢļ│??īĻ│ä?äĒæ£?Ć ņ░©ļ?┬Ę?Ćļ│Ć ?Éļ”ä???ĢņØĖ?śļŖö ?öļ®┤?ģļŗł??"
                            class="fiHeroDescription" />
                    </VBox>
                    <HBox alignItems="Center" class="fiHeroActions">
                        <HBox alignItems="Center" class="fiHeroActionsBox">
                            <Button
                                id="fiGeneralLedgerContentFilterBtn"
                                text="ņĪ░ĒÜī/?äĒä░"
                                icon="sap-icon://filter"
                                type="Transparent"
                                press=".onToolbarFilterOpen"
                                class="fiFilterButton" />
                        </HBox>
                    </HBox>
                </HBox>
            </VBox>

            <HBox class="nxFiMasterDetail nxFiGlWorkspace" width="100%" renderType="Bare">
                <VBox class="nxFiListPane" renderType="Bare">
                    <VBox class="nxFiCard nxFiListCard nxFiGlListCard">
                        <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="{dashboard>/fiGeneralLedger/listTitle}" level="H5" />
                                <Text text="{dashboard>/fiGeneralLedger/listSubtitle}" class="nxFiCardSub" />
                            </VBox>
                            <VBox class="nxFiCardIconWrap nxFiCardIconWrap--list">
                                <core:Icon src="sap-icon://document-text" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>
                        <Table
                            id="fiGeneralLedgerTable"
                            items="{fiGL>/Z_C_FI_GL}"
                            mode="SingleSelectMaster"
                            selectionChange=".onJournalEntrySelect"
                            growing="true"
                            growingThreshold="20"
                            sticky="ColumnHeaders"
                            fixedLayout="Strict"
                            class="nxFiGlTable"
                            noDataText="?░ņØ┤???åņØī"
                            width="100%">
                            <columns>
                                <Column width="7%"><Text text="CompanyCode" /></Column>
                                <Column width="11%"><Text text="AccountingDocument" /></Column>
                                <Column width="6%" hAlign="Center"><Text text="FiscalYear" /></Column>
                                <Column width="9%" hAlign="Center"><Text text="PostingDate" /></Column>
                                <Column width="9%"><Text text="GLAccount" /></Column>
                                <Column width="7%" hAlign="Center"><Text text="DebitCreditCode" /></Column>
                                <Column width="9%" hAlign="End"><Text text="Amount" /></Column>
                                <Column width="6%" hAlign="Center"><Text text="Currency" /></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text="ItemText" /></Column>
                                <Column width="8%" minScreenWidth="Desktop" demandPopin="true"><Text text="CreatedBy" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Active" class="nxFiGlTableRow">
                                    <cells>
                                        <Text text="{fiGL>CompanyCode}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>AccountingDocument}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>FiscalYear}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>PostingDate}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>GLAccount}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>DebitCreditCode}" class="nxFiGlCellEllipsis" />
                                        <ObjectNumber number="{fiGL>Amount}" emphasized="false" />
                                        <Text text="{fiGL>Currency}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>ItemText}" class="nxFiGlCellEllipsis" />
                                        <Text text="{fiGL>CreatedBy}" class="nxFiGlCellEllipsis" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </VBox>

                <VBox class="nxFiDetailPane" renderType="Bare">
                    <VBox class="nxFiCard nxFiDetailCard nxFiGlDetailCard">
                        <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Selected Document Detail" level="H5" />
                                <Text text="?ĀĒāØ ?äĒæ£ ?üņäĖ ?Ģļ│┤" class="nxFiCardSub" />
                            </VBox>
                            <VBox class="nxFiCardIconWrap nxFiCardIconWrap--detail">
                                <core:Icon src="sap-icon://detail-view" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>

                        <VBox
                            visible="{= !${dashboard>/fiGeneralLedger/detail/hasSelection} }"
                            class="fiEmptyState"
                            alignItems="Center"
                            justifyContent="Center">
                            <core:Icon src="sap-icon://cursor" size="2.25rem" color="#9CA3AF" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/fiGeneralLedger/detail/emptyMessage}" class="fiEmptyStateTitle" />
                        </VBox>

                        <VBox
                            visible="{dashboard>/fiGeneralLedger/detail/hasSelection}"
                            class="nxFiGlDetailBody"
                            width="100%">
                            <HBox class="nxFiGlDetailHead" alignItems="Start">
                                <VBox>
                                    <Text text="{dashboard>/fiGeneralLedger/detail/AccountingDocument}" class="nxFiGlDetailDocNo" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/ItemText}" class="nxFiGlDetailDocText" />
                                </VBox>
                            </HBox>
                            <HBox class="nxFiGlDetailTiles" wrap="Wrap" width="100%">
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="CompanyCode" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/CompanyCode}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="FiscalYear" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/FiscalYear}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="PostingDate" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/PostingDate}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="GLAccount" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/GLAccount}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="DebitCreditCode" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/DebitCreditCode}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="Amount" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/AmountDisplay}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="Currency" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/Currency}" class="nxFiGlDetailTileValue" />
                                </VBox>
                                <VBox class="nxFiGlDetailTile">
                                    <Text text="CreatedBy" class="nxFiGlDetailTileLabel" />
                                    <Text text="{dashboard>/fiGeneralLedger/detail/CreatedBy}" class="nxFiGlDetailTileValue" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</mvc:View>
