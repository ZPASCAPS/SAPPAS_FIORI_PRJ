<!--
  FiOverview.view.xml — FI Overview Cockpit (OData 미연결 시 Empty State)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.FiOverview"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxFiOverview fiCockpitPage" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/fiOverview/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/fiOverview/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <BusyIndicator visible="{dashboard>/fiOverview/loading}" class="nxFiOverviewBusy" />

        <VBox visible="{= !${dashboard>/fiOverview/loading} }" width="100%" renderType="Bare" class="nxFiOverviewBody">
            <VBox class="fiFeatureHero fiHeroOverview fiHeroCard" width="100%">
                <HBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="fiHeroCardHead">
                    <VBox class="fiHeroContent fiHeroTextBlock">
                        <Title text="Overview" level="H2" class="fiHeroTitle" />
                        <Text
                            text="재무 전표, 채권·채무, 주요 재무 현황을 한눈에 확인하는 요약 화면입니다."
                            class="fiHeroDescription" />
                    </VBox>
                    <HBox alignItems="Center" class="fiHeroActions">
                        <HBox alignItems="Center" class="fiHeroActionsBox">
                            <Button
                                id="fiOverviewContentFilterBtn"
                                text="조회/필터"
                                icon="sap-icon://filter"
                                type="Transparent"
                                press=".onToolbarFilterOpen"
                                class="fiFilterButton" />
                        </HBox>
                    </HBox>
                </HBox>
            </VBox>

            <MessageStrip
                text="{dashboard>/fiOverview/emptyMessage}"
                type="Information"
                showIcon="true"
                visible="{= !${dashboard>/fiOverview/hasData} }"
                class="sapUiSmallMarginBottom fiOdataStrip" />

            <HBox class="nxFiOverviewSummaryGrid" width="100%" wrap="Wrap" renderType="Bare" items="{dashboard>/fiOverview/summaryCards}">
                <items>
                    <VBox class="nxFiCard nxFiSummaryCard" width="100%">
                        <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="{dashboard>title}" level="H5" />
                                <Text text="{dashboard>subtitle}" class="nxFiCardSub" />
                            </VBox>
                            <VBox class="nxFiCardIconWrap nxFiCardIconWrap--summary">
                                <core:Icon src="sap-icon://chart-axis" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>
                        <VBox class="fiEmptyState" alignItems="Center" justifyContent="Center">
                            <core:Icon src="sap-icon://database" size="2rem" color="#94A3B8" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>emptyMessage}" class="fiEmptyStateTitle" />
                            <Text text="{dashboard>/fiOverview/emptyHint}" class="fiEmptyStateHint" />
                        </VBox>
                    </VBox>
                </items>
            </HBox>

            <VBox class="nxFiCard nxFiWorklistCard" width="100%">
                <HBox class="nxFiCardHead" alignItems="Center" justifyContent="SpaceBetween">
                    <VBox>
                        <Title text="{dashboard>/fiOverview/worklistTitle}" level="H5" />
                        <Text text="{dashboard>/fiOverview/worklistSubtitle}" class="nxFiCardSub" />
                    </VBox>
                    <VBox class="nxFiCardIconWrap nxFiCardIconWrap--worklist">
                        <core:Icon src="sap-icon://list" size="1.1rem" color="#FFFFFF" />
                    </VBox>
                </HBox>
                <VBox class="fiEmptyState fiEmptyState--worklist" alignItems="Center" justifyContent="Center">
                    <core:Icon src="sap-icon://activity-2" size="2rem" color="#94A3B8" class="sapUiSmallMarginBottom" />
                    <Text text="{dashboard>/fiOverview/worklistEmptyMessage}" class="fiEmptyStateTitle" />
                    <Text text="{dashboard>/fiOverview/emptyHint}" class="fiEmptyStateHint" />
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
