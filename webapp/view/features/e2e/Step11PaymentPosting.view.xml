<mvc:View 
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.e2e.Step11PaymentPosting" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">
    
    <VBox class="e2eMtoProcessCard e2eMtoCardPending e2eStepPos11" renderType="Bare">
        <HBox alignItems="Center" justifyContent="SpaceBetween">
            <Text text="11. 입금 전기" class="e2eMtoCardTitle" />
            
            <ObjectStatus 
                text="{= ${flowModel>/Clearing} === '대기중...' || ${flowModel>/Clearing} === '없음' || !${flowModel>/Clearing} ? '예정' : '완료' }" 
                state="{= ${flowModel>/Clearing} === '대기중...' || ${flowModel>/Clearing} === '없음' || !${flowModel>/Clearing} ? 'None' : 'Success' }" 
                class="e2eMtoCardStatus" />
        </HBox>
        
        <Text text="{flowModel>/Clearing}" class="e2eMtoCardDoc" />
        
        <Text text="고객 입금 반영" class="e2eMtoCardDetail" />
    </VBox>
</mvc:View>
