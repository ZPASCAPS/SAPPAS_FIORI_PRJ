<mvc:View 
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.e2e.Step09Billing" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">
    
    <VBox class="e2eMtoProcessCard e2eMtoCardPending e2eStepPos09" renderType="Bare">
        <HBox alignItems="Center" justifyContent="SpaceBetween">
            <Text text="9. 대금 / Billing (청구)" class="e2eMtoCardTitle" />
            
            <ObjectStatus 
                text="{= ${flowModel>/Billing} === '대기중...' || ${flowModel>/Billing} === '없음' || !${flowModel>/Billing} ? '예정' : '완료' }" 
                state="{= ${flowModel>/Billing} === '대기중...' || ${flowModel>/Billing} === '없음' || !${flowModel>/Billing} ? 'None' : 'Success' }" 
                class="e2eMtoCardStatus" />
        </HBox>
        
        <Text text="{flowModel>/Billing}" class="e2eMtoCardDoc" />
        
        <Text text="청구 유형 F2" class="e2eMtoCardDetail" />
    </VBox>
</mvc:View>