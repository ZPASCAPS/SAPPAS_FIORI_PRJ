<mvc:View 
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.e2e.Step10AccountingDocument" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">
    
    <VBox class="e2eMtoProcessCard e2eMtoCardPending e2eStepPos10" renderType="Bare">
        <HBox alignItems="Center" justifyContent="SpaceBetween">
            <Text text="10. 회계전표" class="e2eMtoCardTitle" />
            
            <ObjectStatus 
                text="{= ${flowModel>/FI} === '대기중...' || ${flowModel>/FI} === '없음' || !${flowModel>/FI} ? '예정' : '완료' }" 
                state="{= ${flowModel>/FI} === '대기중...' || ${flowModel>/FI} === '없음' || !${flowModel>/FI} ? 'None' : 'Success' }" 
                class="e2eMtoCardStatus" />
        </HBox>
        
        <Text text="{flowModel>/FI}" class="e2eMtoCardDoc" />
        
        <Text text="회계 전표" class="e2eMtoCardDetail" />
    </VBox>
</mvc:View>
