<!--
  DashboardHeader.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardHeader
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardHeader

  역할:
  - 상단 헤더: 로고·PasCal 브랜드(클릭 → Dashboard), 팀 선택, 검색, 알림, 도움말, 프로필.

  대시보드 구조:
  Main → DashboardMain → DashboardHeader (최상단 가로 바)

  협업:
  - 검색·프로필·Dialog UI → 이 View
  - 검색 필터·프로필 저장·네비 로직 → DashboardHeader.controller.js
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardHeader"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <HBox class="nxHeader appHeader" width="100%" alignItems="Center" justifyContent="SpaceBetween">
        <HBox class="nxHeaderLeft" alignItems="Center">
            <HBox
                id="headerBrand"
                class="nxHeaderBrand nxHeaderBrandClickable"
                alignItems="Center"
                tooltip="Dashboard">
                <Image
                    src="images/pascal-pictogram.svg"
                    densityAware="false"
                    decorative="true"
                    alt="PasCal"
                    class="nxHeaderPictogram" />
                <Text text="PasCal" class="nxHeaderAppName" />
            </HBox>

            <VBox width="1px" height="1.75rem" class="nxHeaderDividerBar" />

            <HBox alignItems="Center" class="nxHeaderTeamSelector">
                <Button
                    id="teamSelectorBtn"
                    text="{dashboard>/team/name}"
                    icon="sap-icon://building"
                    type="Transparent"
                    iconFirst="true"
                    press=".onTeamSelectorPress"
                    class="nxHeaderTeamSelectorBtn" />
                <Button
                    id="teamSelectorArrowBtn"
                    icon="sap-icon://slim-arrow-down"
                    type="Transparent"
                    tooltip="팀 선택"
                    press=".onTeamSelectorPress"
                    class="nxTeamSelectorArrowBtn" />
            </HBox>
        </HBox>

        <HBox alignItems="Center" class="nxHeaderRight">
            <HBox class="nxHeaderSearchArea" alignItems="Center">
                <HBox id="globalSearchWrap" class="nxSearchWrap" alignItems="Center">
                    <Button
                        icon="sap-icon://search"
                        type="Transparent"
                        tooltip="검색"
                        press=".onSearchIconPress"
                        class="nxSearchIconBtn" />
                    <Input
                        id="globalSearch"
                        value="{dashboard>/filters/query}"
                        placeholder="검색어를 입력하세요."
                        submit=".onSearchSubmit"
                        liveChange=".onSearch"
                        class="nxSearchInput" />
                </HBox>
            </HBox>

            <HBox alignItems="Center" class="nxHeaderUtilityBtns">
                <Button
                    id="notificationBtn"
                    icon="sap-icon://bell"
                    type="Transparent"
                    tooltip="알림"
                    press=".onNotifications"
                    class="nxIconBtn" />
                <Button
                    id="headerNotesBtn"
                    icon="sap-icon://notes"
                    type="Transparent"
                    tooltip="메모장"
                    press=".onNotesPress"
                    class="nxIconBtn nxHeaderNotesBtn" />
                <Button
                    id="settingsBtn"
                    icon="sap-icon://action-settings"
                    type="Transparent"
                    tooltip="설정"
                    press=".onSettings"
                    class="nxIconBtn" />
            </HBox>

            <HBox alignItems="Center" class="nxProfile">
                <VBox class="nxProfileAvatarWrap" alignItems="Center" justifyContent="Center">
                    <Image
                        src="images/pas-profile.png"
                        densityAware="false"
                        class="nxProfileAvatarImg"
                        alt="PAS" />
                </VBox>
                <VBox class="nxProfileInfo">
                    <Text text="{dashboard>/user/name}" class="nxProfileName" wrapping="false" />
                    <Text text="{dashboard>/user/role}" class="nxProfileRole" wrapping="false" />
                </VBox>
                <Button
                    id="profileMenuBtn"
                    icon="sap-icon://slim-arrow-down"
                    type="Transparent"
                    tooltip="프로필"
                    press=".onProfile"
                    class="nxProfileMenuBtn" />
            </HBox>
        </HBox>
    </HBox>

    <Popover
        id="searchPopover"
        placement="Bottom"
        contentWidth="22rem"
        showHeader="false"
        class="nxHeaderPopover nxSearchPopover">
        <content>
            <List
                id="searchResultList"
                items="{dashboard>/search/results}"
                showSeparators="Inner"
                noDataText="검색 결과가 없습니다"
                class="nxSearchResultList">
                <StandardListItem
                    title="{dashboard>title}"
                    description="{dashboard>description}"
                    icon="{dashboard>icon}"
                    type="Active"
                    press=".onSearchResultPress" />
            </List>
        </content>
    </Popover>

    <Popover
        id="notificationPopover"
        placement="Bottom"
        contentWidth="22rem"
        contentHeight="18rem"
        showHeader="false"
        afterClose=".onNotificationPopoverAfterClose"
        class="nxHeaderPopover nxNotificationPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody">
                <VBox class="nxHeaderPopoverTitleRow">
                    <Title text="알림" level="H5" class="nxHeaderPopoverTitle" />
                </VBox>
                <List
                    id="notificationList"
                    items="{dashboard>/notifications}"
                    showSeparators="Inner"
                    noDataText="새 알림이 없습니다"
                    class="nxNotificationList">
                    <StandardListItem
                        title="{dashboard>title}"
                        description="{dashboard>description}"
                        icon="{dashboard>icon}"
                        type="Active"
                        press=".onNotificationItemPress" />
                </List>
                <HBox justifyContent="End" alignItems="Center" class="nxPopoverFooter">
                    <Button text="모두 읽음" type="Transparent" press=".onMarkAllNotificationsRead" />
                </HBox>
            </VBox>
        </content>
    </Popover>

    <Popover
        id="teamPopover"
        title="팀 선택"
        placement="Bottom"
        contentWidth="16rem"
        showHeader="true"
        afterClose=".onTeamPopoverAfterClose"
        class="nxHeaderPopover nxTeamPopover">
        <content>
            <List
                id="teamList"
                mode="SingleSelectMaster"
                includeItemInSelection="true"
                items="{dashboard>/teamOptions}"
                selectionChange=".onTeamSelect"
                showSeparators="Inner"
                class="nxTeamList">
                <StandardListItem
                    title="{dashboard>text}"
                    icon="sap-icon://group"
                    type="Active" />
            </List>
        </content>
    </Popover>

    <Popover
        id="settingsPopover"
        placement="Bottom"
        contentWidth="22rem"
        showHeader="false"
        afterClose=".onSettingsPopoverAfterClose"
        class="nxHeaderPopover nxHeaderSettingsPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody">
                <VBox class="nxHeaderPopoverTitleRow">
                    <Title text="설정" level="H5" class="nxHeaderPopoverTitle" />
                </VBox>
                <VBox class="nxSettingsPopoverContent" width="100%">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxSettingsRow">
                        <VBox class="nxSettingsRowText">
                            <Text text="자동 새로고침" class="nxSettingsLabel" />
                            <Text text="5분마다 SAP 데이터 갱신" class="nxSettingsHint" />
                        </VBox>
                        <Switch state="{dashboard>/settings/autoRefresh}" change=".onAutoRefreshChange" />
                    </HBox>
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxSettingsRow">
                        <VBox class="nxSettingsRowText">
                            <Text text="알림 표시" class="nxSettingsLabel" />
                            <Text text="헤더 알림 배지 표시" class="nxSettingsHint" />
                        </VBox>
                        <Switch state="{dashboard>/settings/showNotifications}" change=".onShowNotificationsChange" />
                    </HBox>
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxSettingsRow">
                        <VBox class="nxSettingsRowText">
                            <Text text="다크 모드" class="nxSettingsLabel" />
                            <Text text="어두운 테마로 화면 표시" class="nxSettingsHint" />
                        </VBox>
                        <Switch state="{dashboard>/settings/darkMode}" change=".onDarkModeChange" />
                    </HBox>
                </VBox>
            </VBox>
        </content>
    </Popover>

    <Dialog
        id="profileDialog"
        contentWidth="28rem"
        stretch="false"
        draggable="true"
        resizable="false"
        afterClose=".onProfileDialogAfterClose"
        class="nxProfileDialog">
        <customHeader>
            <Bar class="nxProfileDialogHeaderBar">
                <contentLeft>
                    <Title text="프로필 설정" level="H5" class="nxProfileDialogHeaderTitle" />
                </contentLeft>
            </Bar>
        </customHeader>
        <content>
            <VBox class="nxProfileDialogContent">
                <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxProfileDialogPreview">
                    <HBox alignItems="Center" class="nxProfileDialogPreviewMain">
                    <VBox class="nxProfileAvatarWrap nxProfileAvatarWrapLarge" alignItems="Center" justifyContent="Center">
                        <Image
                            src="images/pas-profile.png"
                            densityAware="false"
                            class="nxProfileAvatarImg"
                            alt="PAS" />
                    </VBox>
                    <VBox class="nxProfileDialogPreviewInfo">
                        <Text text="{dashboard>/user/editName}" class="nxProfileName" />
                        <Text text="{dashboard>/user/editModule}" class="nxProfileRole" />
                    </VBox>
                    </HBox>
                    <VBox alignItems="Center" justifyContent="Center" class="nxProfileDialogQrWrap">
                        <Image
                            id="profileBlogQr"
                            src="{dashboard>/user/blogQrSrc}"
                            densityAware="false"
                            decorative="false"
                            alt="블로그 QR 코드"
                            tooltip="스캔 또는 클릭하면 블로그로 이동합니다"
                            class="nxProfileDialogQr" />
                        <Text text="블로그 QR" class="nxProfileDialogQrHint" />
                    </VBox>
                </HBox>
                <VBox class="nxProfileDialogField">
                    <Label text="이름" class="nxProfileDialogLabel" />
                    <Select
                        selectedKey="{dashboard>/user/editName}"
                        width="100%"
                        forceSelection="false"
                        change=".onProfileNameChange"
                        class="nxProfileDialogSelect"
                        items="{dashboard>/profileOptions/names}">
                        <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                    </Select>
                </VBox>
                <VBox class="nxProfileDialogField">
                    <Label text="모듈" class="nxProfileDialogLabel" />
                    <Select
                        selectedKey="{dashboard>/user/editModule}"
                        width="100%"
                        forceSelection="false"
                        class="nxProfileDialogSelect"
                        items="{dashboard>/profileOptions/modules}">
                        <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                    </Select>
                </VBox>
                <HBox class="nxProfileDialogActions" alignItems="Center" justifyContent="End">
                    <Button text="저장" type="Emphasized" press=".onProfileSave" class="nxProfileDialogSaveBtn" />
                    <Button text="취소" type="Transparent" press=".onProfileCancel" class="nxProfileDialogCancelBtn" />
                </HBox>
            </VBox>
        </content>
    </Dialog>
</mvc:View>
