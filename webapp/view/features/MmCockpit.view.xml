<!--
  MmCockpit.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.MmCockpit
  Controller: com.capstone.dashboard.fioridashboard.controller.features.MmCockpit

  역할:
  - MM Extended 관제 인터랙티브 콕핏 (단일 화면)
  - 상단 차원 토글 → 중앙 카드 가시성 → 하단 상세 테이블 필터 연동

  대시보드 구조:
  DashboardCanvas (navKey=MM_MATERIALS) → MmCockpit

  데이터:
  - 전역 dashboard JSONModel (Main.controller.js _initModels)
  - 바인딩 예: {dashboard>/ui/showPhysicalDiff}, {dashboard>/mmDetailList}
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.MmCockpit"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:layout="sap.ui.layout"
    height="100%"
    width="100%">

    <VBox class="nxMmCockpit" height="100%" width="100%" renderType="Bare">
        <!-- 1. 상단 Extended MM 차원 컨트롤 패널 -->
        <OverflowToolbar class="nxMmCockpitToolbar" design="Transparent">
            <Title text="MM Extended 관제" level="H4" class="nxMmCockpitTitle" />
            <ToolbarSpacer />
            <CheckBox
                text="재고 실사 차이"
                selected="{dashboard>/ui/showPhysicalDiff}"
                select=".onDimensionToggle" />
            <CheckBox
                text="이동 중 재고"
                selected="{dashboard>/ui/showInTransit}"
                select=".onDimensionToggle" />
            <CheckBox
                text="외주 공장 사급"
                selected="{dashboard>/ui/showSubcontract}"
                select=".onDimensionToggle" />
            <CheckBox
                text="보류 및 반품"
                selected="{dashboard>/ui/showBlocked}"
                select=".onDimensionToggle" />
        </OverflowToolbar>

        <!-- 2. 중앙 다이내믹 카드 그리드 -->
        <ScrollContainer
            class="nxMmCockpitGridScroll"
            vertical="true"
            horizontal="false"
            height="auto">
            <cssgrid:Grid
                class="nxMmCockpitGrid"
                gridTemplateColumns="repeat(auto-fit, minmax(18rem, 1fr))"
                gridGap="1rem"
                width="100%">

                <!-- 카드 1: 재고 실사 차이 -->
                <f:Card
                    class="nxMmCard"
                    visible="{dashboard>/ui/showPhysicalDiff}">
                    <f:header>
                        <card:Header
                            title="재고 실사 차이"
                            subtitle="장부 vs 실사 차이 TOP 5"
                            iconSrc="sap-icon://compare"
                            press=".onCardPress">
                            <customData>
                                <core:CustomData key="category" value="PHYSICAL_DIFF" />
                            </customData>
                        </card:Header>
                    </f:header>
                    <f:content>
                        <List
                            class="nxMmCardList"
                            items="{dashboard>/mmCockpit/physicalDiffTop5}"
                            showSeparators="Inner">
                            <StandardListItem
                                title="{dashboard>materialName}"
                                description="{dashboard>materialCode}"
                                info="{dashboard>diffQty}"
                                infoState="Warning"
                                type="Inactive" />
                        </List>
                    </f:content>
                </f:Card>

                <!-- 카드 2: 이동 중 재고 -->
                <f:Card
                    class="nxMmCard"
                    visible="{dashboard>/ui/showInTransit}">
                    <f:header>
                        <card:Header
                            title="이동 중 재고"
                            subtitle="3일 이상 미도착 장기 지연"
                            iconSrc="sap-icon://shipping-status"
                            press=".onCardPress">
                            <customData>
                                <core:CustomData key="category" value="IN_TRANSIT" />
                            </customData>
                        </card:Header>
                    </f:header>
                    <f:content>
                        <VBox class="nxMmKpiBody" alignItems="Center" justifyContent="Center">
                            <ObjectStatus
                                text="장기 지연 오더"
                                state="Error"
                                class="sapUiTinyMarginBottom" />
                            <ObjectNumber
                                number="{dashboard>/mmCockpit/inTransitDelayedCount}"
                                unit="건"
                                emphasized="true"
                                class="nxMmKpiNumber" />
                            <Text
                                text="{dashboard>/mmCockpit/inTransitDelayedHint}"
                                class="nxMmKpiHint sapUiTinyMarginTop" />
                        </VBox>
                    </f:content>
                </f:Card>

                <!-- 카드 3: 외주 공장 사급 -->
                <f:Card
                    class="nxMmCard"
                    visible="{dashboard>/ui/showSubcontract}">
                    <f:header>
                        <card:Header
                            title="외주 공장 사급"
                            subtitle="원자재 고갈 · 리드타임 위험"
                            iconSrc="sap-icon://factory"
                            press=".onCardPress">
                            <customData>
                                <core:CustomData key="category" value="SUBCONTRACT" />
                            </customData>
                        </card:Header>
                    </f:header>
                    <f:content>
                        <List
                            class="nxMmCardList"
                            items="{dashboard>/mmCockpit/subcontractRisks}"
                            showSeparators="Inner">
                            <StandardListItem
                                title="{dashboard>vendorName}"
                                description="{dashboard>materialName}"
                                info="{dashboard>riskLevel}"
                                infoState="{dashboard>riskState}"
                                type="Inactive" />
                        </List>
                    </f:content>
                </f:Card>

                <!-- 카드 4: 보류 및 반품 -->
                <f:Card
                    class="nxMmCard"
                    visible="{dashboard>/ui/showBlocked}">
                    <f:header>
                        <card:Header
                            title="보류 및 반품"
                            subtitle="품질 불합격 · 폐기 대상"
                            iconSrc="sap-icon://locked"
                            press=".onCardPress">
                            <customData>
                                <core:CustomData key="category" value="BLOCKED" />
                            </customData>
                        </card:Header>
                    </f:header>
                    <f:content>
                        <VBox class="nxMmBlockedBody sapUiSmallMargin">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                                <Label text="보류 자산 금액" />
                                <ObjectNumber
                                    number="{dashboard>/mmCockpit/blockedSummary/assetAmount}"
                                    unit="KRW"
                                    emphasized="true" />
                            </HBox>
                            <HBox justifyContent="SpaceBetween" alignItems="Center">
                                <Label text="폐기 대상 수량" />
                                <ObjectNumber
                                    number="{dashboard>/mmCockpit/blockedSummary/scrapQty}"
                                    unit="EA"
                                    state="Error" />
                            </HBox>
                        </VBox>
                    </f:content>
                </f:Card>
            </cssgrid:Grid>
        </ScrollContainer>

        <!-- 3. 하단 상세 액션 테이블 -->
        <VBox class="nxMmCockpitTableWrap" width="100%">
            <Toolbar class="nxMmTableToolbar" design="Transparent">
                <Title
                    text="{dashboard>/ui/mmActiveCategoryLabel}"
                    level="H5"
                    class="nxMmTableTitle" />
                <ToolbarSpacer />
                <Text text="{dashboard>/ui/mmDetailCountLabel}" class="nxMmTableCount" />
            </Toolbar>

            <Table
                id="mmDetailTable"
                class="nxMmDetailTable"
                width="100%"
                growing="true"
                growingScrollToLoad="true"
                items="{dashboard>/mmDetailList}"
                noDataText="표시할 MM Extended 리스크 내역이 없습니다.">
                <columns>
                    <Column><Text text="자재 코드" /></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="자재명" /></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="관리 구분" /></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="이슈 현황/사유" /></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="유관 점포/협력사" /></Column>
                    <Column hAlign="Center" width="8rem"><Text text="조치 액션" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{dashboard>materialCode}" />
                            <Text text="{dashboard>materialName}" />
                            <ObjectStatus text="{dashboard>categoryLabel}" state="{dashboard>categoryState}" />
                            <Text text="{dashboard>issueReason}" />
                            <Text text="{dashboard>plantVendor}" />
                            <Button
                                text="{dashboard>actionText}"
                                type="Emphasized"
                                press=".onActionPress" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </VBox>
</mvc:View>
