<!--
  SectionPlaceholder.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder
  Controller: com.capstone.dashboard.fioridashboard.controller.features.SectionPlaceholder

  역할:
  - 탭별 빈 대시보드 안내 카드 (아이콘 + 제목 + 설명). dashboard/ui/navLabel 등에 바인딩.

  대시보드 구조:
  DashboardCanvas → SectionPlaceholder (모든 탭 공통 안내 화면)

  협업:
  - 안내 UI 디자인 → 이 View + style.css (.nxSectionPlaceholder)
  - 탭별 문구 → ModuleSideNav.controller.js (NAV_LABELS, NAV_DESCRIPTIONS)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.SectionPlaceholder"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="nxSectionPlaceholder">
        <VBox class="nxSectionPlaceholderHero">
            <core:Icon
                src="{dashboard>/ui/navIcon}"
                size="2.5rem"
                color="#0070F2"
                class="sapUiMediumMarginBottom" />
            <Title text="{dashboard>/ui/navLabel}" level="H2" class="nxSectionPlaceholderTitle" />
            <Text text="{dashboard>/ui/navDescription}" class="nxSectionPlaceholderDesc" />
        </VBox>
    </VBox>
</mvc:View>
