<!--
  MmInventory.view.xml — MM Inventory master-detail (Z_C_MM_INVENTORY_CDS)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.MmInventory"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxMmInventory mmInventoryPage" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/mmInventory/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/mmInventory/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <BusyIndicator visible="{dashboard>/mmInventory/loading}" class="nxMmInventoryBusy" />

        <VBox visible="{= !${dashboard>/mmInventory/loading} }" width="100%" renderType="Bare" class="nxMmInventoryBody">
            <VBox class="mmFeatureHero mmHeroInventory mmHeroCard" width="100%">
                <HBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="mmHeroCardHead">
                    <VBox class="mmHeroContent">
                        <Title text="Inventory" level="H2" class="mmHeroTitle" />
                        <Text
                            text="자재별 재고 수량과 보관 위치, 품질/보류 재고 상태를 확인하는 화면"
                            class="mmHeroDescription" />
                    </VBox>
                    <HBox alignItems="Center" class="mmHeroActions">
                        <HBox alignItems="Center" class="mmHeroActionsBox">
                            <Button
                                id="mmInventoryContentFilterBtn"
                                text="조회/필터"
                                icon="sap-icon://filter"
                                type="Transparent"
                                press=".onToolbarFilterOpen"
                                class="mmFilterButton" />
                        </HBox>
                    </HBox>
                </HBox>
                <HBox class="mmHeroKpiStrip" wrap="Wrap" items="{dashboard>/mmInventory/kpis}">
                    <items>
                        <VBox class="mmHeroKpiItem">
                            <HBox alignItems="Center" justifyContent="SpaceBetween">
                                <Text text="{dashboard>displayTitle}" class="mmHeroKpiLabel" />
                                <core:Icon src="{dashboard>icon}" size="0.9rem" color="#FFFFFF" />
                            </HBox>
                            <HBox alignItems="Baseline" class="mmHeroKpiValueRow">
                                <Text text="{dashboard>value}" class="mmHeroKpiValue" />
                                <Text text="{dashboard>unit}" visible="{= !!${dashboard>unit} }" class="mmHeroKpiUnit" />
                            </HBox>
                            <Text text="{dashboard>hint}" class="mmHeroKpiHint" />
                        </VBox>
                    </items>
                </HBox>
            </VBox>

            <HBox class="nxMmInventoryMain" width="100%" renderType="Bare">
                <VBox class="nxMmInventoryListPane" renderType="Bare">
                    <VBox class="nxMmInventoryCard nxMmInventoryTableCard">
                        <HBox class="nxMmInventoryCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Material Stock List" level="H5" />
                                <Text text="자재·플랜트·저장위치별 재고 목록" class="nxMmInventoryCardSub" />
                            </VBox>
                            <HBox alignItems="Center" class="nxMmInventoryCardHeadActions">
                                <ObjectStatus
                                    text="{= ${dashboard>/mmInventory/materials}.length + ' EA' }"
                                    state="Information"
                                    icon="sap-icon://list" />
                                <VBox class="nxMmInventoryCardIconWrap nxMmInventoryCardIconWrap--table">
                                    <core:Icon src="sap-icon://table-view" size="1.1rem" color="#FFFFFF" />
                                </VBox>
                            </HBox>
                        </HBox>
                        <Table
                            id="mmInventoryMaterialTable"
                            items="{dashboard>/mmInventory/materials}"
                            mode="SingleSelectMaster"
                            selectionChange=".onMaterialSelect"
                            growing="true"
                            growingThreshold="15"
                            sticky="ColumnHeaders"
                            class="nxMmInventoryTable"
                            width="100%">
                            <columns>
                                <Column width="11%"><Text text="Material" /></Column>
                                <Column width="18%"><Text text="Material Name" /></Column>
                                <Column width="8%" hAlign="Center"><Text text="Plant" /></Column>
                                <Column width="8%" hAlign="Center"><Text text="Storage Loc." /></Column>
                                <Column width="9%" hAlign="Center"><Text text="Type" /></Column>
                                <Column width="11%" hAlign="End"><Text text="Stock Qty" /></Column>
                                <Column width="11%" hAlign="End"><Text text="QI Stock" /></Column>
                                <Column width="11%" hAlign="End"><Text text="Blocked" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Active" class="nxMmInventoryTableRow">
                                    <cells>
                                        <Text text="{dashboard>materialNo}" class="nxMmInventoryCode" />
                                        <Text text="{dashboard>materialName}" class="nxMmInventoryCellEllipsis" />
                                        <Text text="{dashboard>plant}" class="nxMmInventoryCellEllipsis" />
                                        <Text text="{dashboard>storageLocation}" class="nxMmInventoryCellEllipsis" />
                                        <ObjectStatus text="{dashboard>materialType}" state="Information" class="nxMmInventoryTypeBadge" />
                                        <ObjectNumber
                                            number="{dashboard>stockQty}"
                                            unit="{dashboard>baseUnit}"
                                            emphasized="true" />
                                        <ObjectNumber number="{dashboard>qualityInspectionStock}" unit="{dashboard>baseUnit}" />
                                        <ObjectNumber
                                            number="{dashboard>blockedStock}"
                                            unit="{dashboard>baseUnit}"
                                            state="{= ${dashboard>blockedStock} > 0 ? 'Error' : 'None' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </VBox>

                <VBox class="nxMmInventoryDetailPane" renderType="Bare">
                    <VBox class="nxMmInventoryCard nxMmInventoryDetailCard">
                        <HBox class="nxMmInventoryCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Selected Material Detail" level="H5" />
                                <Text text="선택 자재 상세 재고 정보" class="nxMmInventoryCardSub" />
                            </VBox>
                            <VBox class="nxMmInventoryCardIconWrap nxMmInventoryCardIconWrap--detail">
                                <core:Icon src="sap-icon://product" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>

                        <VBox
                            visible="{= !${dashboard>/mmInventory/detail/hasSelection} }"
                            class="nxMmInventoryDetailEmpty"
                            alignItems="Center"
                            justifyContent="Center">
                            <core:Icon src="sap-icon://cursor" size="2.25rem" color="#9CA3AF" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/mmInventory/detail/emptyMessage}" class="nxMmInventoryDetailEmptyText" />
                        </VBox>

                        <VBox
                            visible="{dashboard>/mmInventory/detail/hasSelection}"
                            class="nxMmInventoryDetailBody"
                            width="100%">
                            <HBox alignItems="Start" class="nxMmInventoryDetailHead">
                                <VBox class="nxMmInventoryDetailHeadText">
                                    <Text text="{dashboard>/mmInventory/detail/materialNo}" class="nxMmInventoryDetailMatNo" />
                                    <Text text="{dashboard>/mmInventory/detail/materialName}" class="nxMmInventoryDetailMatName" />
                                </VBox>
                            </HBox>

                            <MessageStrip
                                text="{dashboard>/mmInventory/detail/infoMessage}"
                                type="Information"
                                showIcon="true"
                                visible="{= !!${dashboard>/mmInventory/detail/infoMessage} }"
                                class="nxMmInventoryDetailStrip" />

                            <HBox class="nxMmInventoryDetailTiles" wrap="Wrap" width="100%">
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Plant" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/plant}" class="nxMmInventoryDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Storage Location" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/storageLocation}" class="nxMmInventoryDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Material Type" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/materialType}" class="nxMmInventoryDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Stock Qty" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/stockQty}" class="nxMmInventoryDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Quality Inspection Stock" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/qualityInspectionStock}" class="nxMmInventoryDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmInventoryDetailTile">
                                    <Text text="Blocked Stock" class="nxMmInventoryDetailTileLabel" />
                                    <Text text="{dashboard>/mmInventory/detail/blockedStock}" class="nxMmInventoryDetailTileValue nxMmInventoryDetailTileValue--danger" />
                                </VBox>
                            </HBox>

                            <HBox alignItems="Center" class="nxMmInventoryDetailSourceRow">
                                <core:Icon src="sap-icon://database" size="0.75rem" color="#9CA3AF" class="sapUiTinyMarginEnd" />
                                <Text text="{dashboard>/mmInventory/detail/dataSource}" class="nxMmInventoryDetailSource" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>

            <VBox class="nxMmInventoryAnalysisPanel mmInventoryAnalysis" width="100%" renderType="Bare">
                <HBox class="nxMmInventoryAnalysisHead" alignItems="Center" justifyContent="SpaceBetween" width="100%">
                    <VBox>
                        <Title text="Inventory Analysis" level="H5" class="nxMmInventoryAnalysisTitle" />
                        <Text text="MaterialType · Plant별 StockQty" class="nxMmInventoryAnalysisSub" />
                    </VBox>
                    <ObjectStatus text="Z_C_MM_INVENTORY" state="Success" icon="sap-icon://database" />
                </HBox>
                <VBox class="nxMmInventoryChartGrid" width="100%" renderType="Bare" items="{dashboard>/mmInventory/analysisCharts}">
                    <items>
                        <VBox class="{= 'nxMmInventoryChartCard nxMmInventoryChartCard--' + ${dashboard>cardKey} }" renderType="Bare">
                            <HBox class="nxMmInventoryCardHead" alignItems="Center" justifyContent="SpaceBetween">
                                <VBox>
                                    <Title text="{dashboard>title}" level="H5" />
                                    <Text text="{dashboard>subtitle}" class="nxMmInventoryCardSub" />
                                </VBox>
                                <VBox class="{= 'nxMmInventoryCardIconWrap nxMmInventoryCardIconWrap--' + ${dashboard>cardKey} }">
                                    <core:Icon src="{dashboard>icon}" size="1.1rem" color="#FFFFFF" />
                                </VBox>
                            </HBox>
                            <VBox class="nxMmInventoryChartBody" width="100%">
                                <core:HTML content="{dashboard>html}" />
                            </VBox>
                        </VBox>
                    </items>
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
