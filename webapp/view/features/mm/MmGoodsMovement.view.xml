<!--
  MmGoodsMovement.view.xml — Movement Flow Monitor (SAP OData)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.mm.MmGoodsMovement"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxMmGoodsMovement nxMmGmFlow" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/mmGoodsMovement/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/mmGoodsMovement/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <BusyIndicator visible="{dashboard>/mmGoodsMovement/loading}" class="nxMmGoodsMovementBusy" />

        <VBox visible="{= !${dashboard>/mmGoodsMovement/loading} }" width="100%" renderType="Bare" class="nxMmGoodsMovementBody">
            <VBox class="mmFeatureHero mmHeroMovement mmHeroCard" width="100%">
                <HBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="mmHeroCardHead">
                    <VBox class="mmHeroContent">
                        <Title text="Goods Movement" level="H2" class="mmHeroTitle" />
                        <Text
                            text="자재 입출고 전표와 이동 흐름, 재고 영향 여부를 확인하는 화면"
                            class="mmHeroDescription" />
                    </VBox>
                    <HBox alignItems="Center" class="mmHeroActions">
                        <HBox alignItems="Center" class="mmHeroActionsBox">
                            <Button
                                id="mmGoodsMovementContentFilterBtn"
                                text="조회/필터"
                                icon="sap-icon://filter"
                                type="Transparent"
                                press=".onToolbarFilterOpen"
                                class="mmFilterButton" />
                        </HBox>
                    </HBox>
                </HBox>
                <HBox class="mmHeroKpiStrip" wrap="Wrap" items="{dashboard>/mmGoodsMovement/heroKpis}">
                    <items>
                        <VBox class="mmHeroKpiItem">
                            <HBox alignItems="Center" justifyContent="SpaceBetween">
                                <Text text="{dashboard>displayTitle}" class="mmHeroKpiLabel" />
                                <core:Icon src="{dashboard>icon}" size="0.9rem" color="#FFFFFF" />
                            </HBox>
                            <HBox alignItems="Baseline" class="mmHeroKpiValueRow">
                                <Text text="{dashboard>value}" class="mmHeroKpiValue" />
                                <Text text="{dashboard>unit}" visible="{= !!${dashboard>unit} }" class="mmHeroKpiUnit" />
                            </HBox>
                            <Text text="{dashboard>hint}" class="mmHeroKpiHint" />
                        </VBox>
                    </items>
                </HBox>
            </VBox>

            <HBox class="nxMmGmStatusStrip" wrap="Wrap" width="100%" items="{dashboard>/mmGoodsMovement/statusStrip}">
                <items>
                    <VBox class="{= 'nxMmGmStatusSegment nxMmGmStatusSegment--' + ${dashboard>accent} }">
                        <HBox alignItems="Center" justifyContent="SpaceBetween">
                            <Text text="{dashboard>title}" class="nxMmGmStatusLabel" />
                            <core:Icon src="{dashboard>icon}" size="1rem" />
                        </HBox>
                        <ObjectNumber number="{dashboard>value}" unit="{dashboard>unit}" emphasized="true" class="nxMmGmStatusNum" />
                        <Text text="{dashboard>hint}" class="nxMmGmStatusHint" />
                    </VBox>
                </items>
            </HBox>

            <HBox class="nxMmGmWorkspace" width="100%" renderType="Bare">
                <VBox class="nxMmGmQueuePane" renderType="Bare">
                    <VBox class="nxMmGoodsMovementCard nxMmGmQueueCard">
                        <HBox class="nxMmGoodsMovementCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Movement Document Queue" level="H5" />
                                <Text text="MIGO 전표 Linked / Missing" class="nxMmGoodsMovementCardSub" />
                            </VBox>
                            <ObjectStatus
                                text="{= ${dashboard>/mmGoodsMovement/documentQueue/linkedCount} + ' / ' + ${dashboard>/mmGoodsMovement/documentQueue/missingCount} }"
                                state="Information"
                                icon="sap-icon://documents" />
                        </HBox>

                        <ScrollContainer vertical="true" horizontal="false" height="24rem" width="100%" class="nxMmGmQueueScroll">
                            <VBox width="100%" renderType="Bare" class="nxMmGmQueueGroups">
                                <VBox width="100%" renderType="Bare" class="nxMmGmQueueGroup">
                                    <HBox alignItems="Center" class="nxMmGmQueueGroupHead">
                                        <core:Icon src="sap-icon://accept" size="0.85rem" color="#36A41D" class="sapUiTinyMarginEnd" />
                                        <Title text="Linked Documents" level="H6" />
                                        <ObjectStatus text="{dashboard>/mmGoodsMovement/documentQueue/linkedCount}" state="Success" class="sapUiTinyMarginBegin" />
                                    </HBox>
                                    <List
                                        id="mmGmLinkedQueue"
                                        items="{dashboard>/mmGoodsMovement/documentQueue/linkedDocuments}"
                                        mode="SingleSelectMaster"
                                        selectionChange=".onDocumentSelect"
                                        class="nxMmGmDocList"
                                        width="100%">
                                        <CustomListItem type="Active" class="nxMmGmDocItem nxMmGmDocItem--linked">
                                            <VBox class="nxMmGmDocItemBody" width="100%">
                                                <HBox alignItems="Center" justifyContent="SpaceBetween">
                                                    <Text text="{dashboard>migoDoc}" class="nxMmGmDocMigo" />
                                                    <ObjectStatus text="{dashboard>linkStatus}" state="{dashboard>linkStatusState}" />
                                                </HBox>
                                                <Text text="{= ${dashboard>poNo} + ' · ' + ${dashboard>materialNo} }" class="nxMmGmDocMeta" />
                                            </VBox>
                                        </CustomListItem>
                                    </List>
                                </VBox>

                                <VBox width="100%" renderType="Bare" class="nxMmGmQueueGroup">
                                    <HBox alignItems="Center" class="nxMmGmQueueGroupHead">
                                        <core:Icon src="sap-icon://warning" size="0.85rem" color="#E67E22" class="sapUiTinyMarginEnd" />
                                        <Title text="Missing MIGO" level="H6" />
                                        <ObjectStatus text="{dashboard>/mmGoodsMovement/documentQueue/missingCount}" state="Warning" class="sapUiTinyMarginBegin" />
                                    </HBox>
                                    <List
                                        id="mmGmMissingQueue"
                                        items="{dashboard>/mmGoodsMovement/documentQueue/missingDocuments}"
                                        mode="SingleSelectMaster"
                                        selectionChange=".onDocumentSelect"
                                        class="nxMmGmDocList"
                                        width="100%">
                                        <CustomListItem type="Active" class="nxMmGmDocItem nxMmGmDocItem--missing">
                                            <VBox class="nxMmGmDocItemBody" width="100%">
                                                <HBox alignItems="Center" justifyContent="SpaceBetween">
                                                    <Text text="{dashboard>migoDoc}" class="nxMmGmDocMigo" />
                                                    <ObjectStatus text="{dashboard>linkStatus}" state="{dashboard>linkStatusState}" />
                                                </HBox>
                                                <Text text="{= ${dashboard>poNo} + ' · ' + ${dashboard>materialNo} }" class="nxMmGmDocMeta" />
                                            </VBox>
                                        </CustomListItem>
                                    </List>
                                </VBox>
                            </VBox>
                        </ScrollContainer>
                    </VBox>
                </VBox>

                <VBox class="nxMmGmFlowPane" renderType="Bare">
                    <VBox class="nxMmGoodsMovementCard nxMmGmFlowCard">
                        <HBox class="nxMmGoodsMovementCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Selected Movement Flow" level="H5" />
                                <Text text="PO → MIGO → Material → Stock Status" class="nxMmGoodsMovementCardSub" />
                            </VBox>
                            <VBox class="nxMmGoodsMovementCardIconWrap nxMmGoodsMovementCardIconWrap--migo">
                                <core:Icon src="sap-icon://journey-change" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>

                        <VBox visible="{= !${dashboard>/mmGoodsMovement/movementFlow/hasFlow} }" class="nxMmGoodsMovementDetailEmpty" alignItems="Center" justifyContent="Center">
                            <core:Icon src="sap-icon://journey-change" size="2.25rem" color="#9CA3AF" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/mmGoodsMovement/movementFlow/emptyMessage}" class="nxMmGoodsMovementDetailEmptyText" />
                        </VBox>

                        <VBox visible="{dashboard>/mmGoodsMovement/movementFlow/hasFlow}" class="nxMmGmFlowBody" width="100%">
                            <HBox class="nxMmGmFlowSteps" wrap="Wrap" items="{dashboard>/mmGoodsMovement/movementFlow/steps}">
                                <items>
                                    <HBox alignItems="Center" class="nxMmGmFlowStepWrap">
                                        <VBox class="nxMmGmFlowStep">
                                            <core:Icon src="{dashboard>icon}" size="1.25rem" color="#0070F2" class="nxMmGmFlowStepIcon" />
                                            <Text text="{dashboard>label}" class="nxMmGmFlowStepLabel" />
                                            <Text text="{dashboard>value}" class="nxMmGmFlowStepValue" />
                                            <ObjectStatus text="{= ${dashboard>state} === 'Success' ? '연결됨' : (${dashboard>state} === 'Warning' ? '확인 필요' : '데이터 없음') }" state="{dashboard>state}" />
                                        </VBox>
                                        <core:Icon src="sap-icon://slim-arrow-right" size="1.1rem" color="#36A41D" class="nxMmGmFlowArrow" visible="{= ${dashboard>key} !== 'stock' }" />
                                    </HBox>
                                </items>
                            </HBox>

                            <HBox class="nxMmGmFlowMetrics" wrap="Wrap" width="100%">
                                <VBox class="nxMmGmFlowMetric">
                                    <Text text="Stock Qty" class="nxMmGmFlowMetricLabel" />
                                    <Text text="{dashboard>/mmGoodsMovement/movementFlow/stockQty}" class="nxMmGmFlowMetricValue" />
                                </VBox>
                                <VBox class="nxMmGmFlowMetric">
                                    <Text text="Required Qty" class="nxMmGmFlowMetricLabel" />
                                    <Text text="{dashboard>/mmGoodsMovement/movementFlow/requiredQty}" class="nxMmGmFlowMetricValue" />
                                </VBox>
                                <VBox class="nxMmGmFlowMetric">
                                    <Text text="Shortage Qty" class="nxMmGmFlowMetricLabel" />
                                    <Text text="{dashboard>/mmGoodsMovement/movementFlow/shortageQty}" class="nxMmGmFlowMetricValue nxMmGmFlowMetricValue--danger" />
                                </VBox>
                                <VBox class="nxMmGmFlowMetric">
                                    <Text text="Fill Rate" class="nxMmGmFlowMetricLabel" />
                                    <Text text="{dashboard>/mmGoodsMovement/movementFlow/fillRate}" class="nxMmGmFlowMetricValue" />
                                </VBox>
                            </HBox>

                            <ProgressIndicator
                                percentValue="{dashboard>/mmGoodsMovement/movementFlow/fillRatePercent}"
                                displayValue="{dashboard>/mmGoodsMovement/movementFlow/fillRate}"
                                state="{dashboard>/mmGoodsMovement/movementFlow/fillRateState}"
                                width="100%"
                                class="nxMmGoodsMovementDetailFillBar" />

                            <VBox class="nxMmGmMissingFields" width="100%">
                                <Title text="미제공 이동 필드" level="H6" class="nxMmGmMissingTitle" />
                                <HBox wrap="Wrap" items="{dashboard>/mmGoodsMovement/movementFlow/missingFields}" class="nxMmGmMissingList">
                                    <items>
                                        <VBox class="nxMmGmMissingChip">
                                            <Text text="{dashboard>label}" class="nxMmGmMissingChipLabel" />
                                            <Text text="{dashboard>value}" class="nxMmGmMissingChipValue" />
                                        </VBox>
                                    </items>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </VBox>

                <VBox class="nxMmGmStockPane" renderType="Bare">
                    <VBox class="nxMmGoodsMovementCard nxMmGmStockCard">
                        <HBox class="nxMmGoodsMovementCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Stock Impact" level="H5" />
                                <Text text="재고 반영 · Data Availability" class="nxMmGoodsMovementCardSub" />
                            </VBox>
                            <VBox class="nxMmGoodsMovementCardIconWrap nxMmGoodsMovementCardIconWrap--impact">
                                <core:Icon src="sap-icon://inventory" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>

                        <VBox visible="{= !${dashboard>/mmGoodsMovement/stockPanel/hasSelection} }" class="nxMmGoodsMovementDetailEmpty" alignItems="Center" justifyContent="Center">
                            <Text text="{dashboard>/mmGoodsMovement/stockPanel/emptyMessage}" class="nxMmGoodsMovementDetailEmptyText" />
                        </VBox>

                        <VBox visible="{dashboard>/mmGoodsMovement/stockPanel/hasSelection}" class="nxMmGmStockBody" width="100%">
                            <MessageStrip text="{dashboard>/mmGoodsMovement/stockPanel/warningMessage}" type="Warning" showIcon="true"
                                visible="{= !!${dashboard>/mmGoodsMovement/stockPanel/warningMessage} }" class="sapUiTinyMarginBottom" />
                            <MessageStrip text="{dashboard>/mmGoodsMovement/stockPanel/successMessage}" type="Success" showIcon="true"
                                visible="{= !!${dashboard>/mmGoodsMovement/stockPanel/successMessage} }" class="sapUiTinyMarginBottom" />

                            <VBox class="nxMmGmStockTile nxMmGmStockTile--status">
                                <Text text="Material Status" class="nxMmGmStockTileLabel" />
                                <ObjectStatus text="{dashboard>/mmGoodsMovement/stockPanel/materialStatus}" state="{dashboard>/mmGoodsMovement/stockPanel/materialStatusState}" />
                            </VBox>
                            <VBox class="nxMmGmStockTile">
                                <Text text="Stock Qty" class="nxMmGmStockTileLabel" />
                                <Text text="{dashboard>/mmGoodsMovement/stockPanel/stockQty}" class="nxMmGmStockTileValue" />
                            </VBox>
                            <VBox class="nxMmGmStockTile">
                                <Text text="Shortage Qty" class="nxMmGmStockTileLabel" />
                                <Text text="{dashboard>/mmGoodsMovement/stockPanel/shortageQty}" class="nxMmGmStockTileValue nxMmGmStockTileValue--danger" />
                            </VBox>
                            <VBox class="nxMmGmStockTile">
                                <Text text="Available Stock" class="nxMmGmStockTileLabel" />
                                <Text text="{dashboard>/mmGoodsMovement/stockPanel/availableStock}" class="nxMmGmStockTileValue" />
                            </VBox>
                            <VBox class="nxMmGmStockTile">
                                <Text text="Fill Rate" class="nxMmGmStockTileLabel" />
                                <Text text="{dashboard>/mmGoodsMovement/stockPanel/fillRate}" class="nxMmGmStockTileValue" />
                            </VBox>

                            <VBox class="nxMmGmAvailSection" width="100%">
                                <Title text="Data Availability" level="H6" class="nxMmGmAvailTitle" />
                                <List items="{dashboard>/mmGoodsMovement/stockPanel/dataAvailability}" showSeparators="None" class="nxMmGmAvailList">
                                    <CustomListItem class="nxMmGmAvailRow">
                                        <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                                            <Text text="{dashboard>label}" class="nxMmGmAvailLabel" />
                                            <ObjectStatus text="{dashboard>value}" state="{= ${dashboard>ok} ? 'Success' : 'None' }" />
                                        </HBox>
                                    </CustomListItem>
                                </List>
                            </VBox>
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>

            <VBox class="nxMmGmAnalysisPanel" width="100%" renderType="Bare">
                <HBox class="nxMmGmAnalysisHead" alignItems="Center" justifyContent="SpaceBetween" width="100%">
                    <VBox>
                        <Title text="Movement Analysis" level="H5" />
                        <Text text="MIGO 문서 · 재고 반영 · 미제공 필드" class="nxMmGoodsMovementAnalysisSub" />
                    </VBox>
                    <ObjectStatus text="MIGO/재고 중심" state="Success" icon="sap-icon://bar-chart" />
                </HBox>
                <HBox class="nxMmGmAnalysisGrid" wrap="Wrap" width="100%" items="{dashboard>/mmGoodsMovement/analysisCards}">
                    <items>
                        <VBox class="{= 'nxMmGmAnalysisCard nxMmGmAnalysisCard--' + ${dashboard>cardKey} }" renderType="Bare">
                            <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxMmGmAnalysisCardHead">
                                <VBox>
                                    <Title text="{dashboard>title}" level="H5" />
                                    <Text text="{dashboard>subtitle}" class="nxMmGoodsMovementCardSub" />
                                </VBox>
                                <core:Icon src="{dashboard>icon}" size="1rem" color="#36A41D" />
                            </HBox>
                            <VBox class="nxMmGmAnalysisBody" width="100%">
                                <core:HTML content="{dashboard>html}" />
                            </VBox>
                        </VBox>
                    </items>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
