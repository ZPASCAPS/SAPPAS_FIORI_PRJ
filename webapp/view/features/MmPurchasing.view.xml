<!--
  MmPurchasing.view.xml — Procurement Control Tower (SAP OData)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.MmPurchasing"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxMmPurchasing nxMmPurchTower" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/mmPurchasing/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/mmPurchasing/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <BusyIndicator visible="{dashboard>/mmPurchasing/loading}" class="nxMmPurchasingBusy" />

        <VBox visible="{= !${dashboard>/mmPurchasing/loading} }" width="100%" renderType="Bare" class="nxMmPurchasingBody">
            <VBox class="nxMmPurchasingHero nxMmPurchTowerHero">
                <HBox alignItems="Center" justifyContent="SpaceBetween" wrap="Wrap" class="nxMmPurchasingHeroTop">
                    <VBox class="nxMmPurchasingHeroText">
                        <HBox alignItems="Center" class="nxMmPurchasingBadgeRow">
                            <ObjectStatus text="LIVE SAP DATA" state="Success" icon="sap-icon://connected" class="nxMmPurchasingLiveBadge" />
                            <ObjectStatus text="Procurement Control Tower" state="Information" icon="sap-icon://customer-order-entry" class="sapUiTinyMarginBegin" />
                        </HBox>
                        <Title text="Purchasing Control Tower" level="H2" class="nxMmPurchasingHeroTitle" />
                        <Text
                            text="PO 번호와 MIGO 전표, 자재 연결 상태를 통해 구매 진행 흐름과 조달 리스크를 확인합니다."
                            class="nxMmPurchasingHeroSub" />
                        <Text
                            text="{= '현재 필터: ' + ${dashboard>/mmPurchasing/criteriaLabel} + ' · Last Updated: ' + ${dashboard>/mmPurchasing/lastUpdated} }"
                            class="nxMmPurchasingHeroMeta" />
                    </VBox>
                    <VBox alignItems="End" class="nxMmPurchasingHeroActions">
                        <Button text="SAP 새로고침" icon="sap-icon://refresh" type="Emphasized" press=".onRefreshPress" class="nxMmPurchasingRefreshBtn" />
                    </VBox>
                </HBox>
            </VBox>

            <VBox class="nxMmPurchPipeline" width="100%" renderType="Bare">
                <Title text="Procurement Pipeline" level="H5" class="nxMmPurchPipelineTitle" />
                <HBox class="nxMmPurchPipelineFlow" wrap="Wrap" items="{dashboard>/mmPurchasing/pipeline}">
                    <items>
                        <HBox alignItems="Center" class="nxMmPurchPipelineStepWrap">
                            <VBox class="{= 'nxMmPurchPipelineStep nxMmPurchPipelineStep--' + ${dashboard>accent} }">
                                <HBox alignItems="Center" justifyContent="SpaceBetween">
                                    <Text text="{dashboard>title}" class="nxMmPurchPipelineStepLabel" />
                                    <core:Icon src="{dashboard>icon}" size="1rem" class="nxMmPurchPipelineStepIcon" />
                                </HBox>
                                <ObjectNumber number="{dashboard>value}" unit="{dashboard>unit}" emphasized="true" class="nxMmPurchPipelineStepNum" />
                                <Text text="{dashboard>hint}" class="nxMmPurchPipelineStepHint" />
                            </VBox>
                            <core:Icon
                                src="sap-icon://slim-arrow-right"
                                size="1.25rem"
                                color="#F59E0B"
                                visible="{dashboard>showArrow}"
                                class="nxMmPurchPipelineArrow" />
                        </HBox>
                    </items>
                </HBox>
            </VBox>

            <HBox class="nxMmPurchWorkspace" width="100%" renderType="Bare">
                <VBox class="nxMmPurchRiskPane" renderType="Bare">
                    <VBox class="nxMmPurchasingCard nxMmPurchRiskCard">
                        <HBox class="nxMmPurchasingCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Procurement Risk Queue" level="H5" />
                                <Text text="부족 자재 조달 연결 확인" class="nxMmPurchasingCardSub" />
                            </VBox>
                            <ObjectStatus text="{= ${dashboard>/mmPurchasing/riskQueue}.length + ' EA' }" state="Error" icon="sap-icon://alert" />
                        </HBox>
                        <List
                            id="mmPurchasingRiskQueue"
                            items="{dashboard>/mmPurchasing/riskQueue}"
                            mode="SingleSelectMaster"
                            selectionChange=".onRiskQueueSelect"
                            growing="true"
                            growingThreshold="12"
                            class="nxMmPurchRiskList"
                            width="100%">
                            <CustomListItem type="Active" class="{= 'nxMmPurchRiskItem nxMmPurchRiskItem--' + ${dashboard>accentClass} }">
                                <VBox class="nxMmPurchRiskItemBody" width="100%">
                                    <HBox alignItems="Center" justifyContent="SpaceBetween">
                                        <Text text="{dashboard>materialNo}" class="nxMmPurchRiskMat" />
                                        <ObjectStatus text="{dashboard>riskLevel}" state="{dashboard>riskLevelState}" />
                                    </HBox>
                                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxMmPurchRiskMeta">
                                        <Text text="{= 'Shortage: ' + ${dashboard>shortageQty} }" class="nxMmPurchRiskShort" />
                                        <HBox alignItems="Center" class="nxMmPurchRiskLinks">
                                            <ObjectStatus text="{dashboard>poLinked}" state="{dashboard>poLinkedState}" class="sapUiTinyMarginEnd" />
                                            <ObjectStatus text="{dashboard>migoLinked}" state="{dashboard>migoLinkedState}" />
                                        </HBox>
                                    </HBox>
                                    <Text text="{dashboard>actionText}" class="nxMmPurchRiskAction" />
                                </VBox>
                            </CustomListItem>
                        </List>
                    </VBox>
                </VBox>

                <VBox class="nxMmPurchBoardPane" renderType="Bare">
                    <VBox class="nxMmPurchasingCard nxMmPurchBoardCard">
                        <HBox class="nxMmPurchasingCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="PO / MIGO Tracker Board" level="H5" />
                                <Text text="구매 추적 보드 · Compact View" class="nxMmPurchasingCardSub" />
                            </VBox>
                            <VBox class="nxMmPurchasingCardIconWrap nxMmPurchasingCardIconWrap--table">
                                <core:Icon src="sap-icon://table-view" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>
                        <ScrollContainer vertical="true" horizontal="false" height="22rem" width="100%" class="nxMmPurchBoardScroll">
                            <Table
                                id="mmPurchasingTrackerTable"
                                items="{dashboard>/mmPurchasing/trackers}"
                                mode="SingleSelectMaster"
                                selectionChange=".onTrackerSelect"
                                class="nxMmPurchasingTable nxMmPurchBoardTable"
                                width="100%">
                                <columns>
                                    <Column width="14%"><Text text="PO No" /></Column>
                                    <Column width="16%"><Text text="Material No" /></Column>
                                    <Column width="16%"><Text text="MIGO Doc" /></Column>
                                    <Column width="12%" hAlign="Center"><Text text="PO Status" /></Column>
                                    <Column width="12%" hAlign="Center"><Text text="MIGO Status" /></Column>
                                    <Column width="30%" hAlign="Center"><Text text="Procurement Status" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Active" class="nxMmPurchasingTableRow">
                                        <cells>
                                            <Text text="{dashboard>poNo}" class="nxMmPurchasingCode nxMmPurchasingCellEllipsis" />
                                            <Text text="{dashboard>materialNo}" class="nxMmPurchasingCellEllipsis" />
                                            <Text text="{dashboard>migoDoc}" class="nxMmPurchasingCellEllipsis" />
                                            <ObjectStatus text="{dashboard>poStatus}" state="{dashboard>poStatusState}" />
                                            <ObjectStatus text="{dashboard>migoStatus}" state="{dashboard>migoStatusState}" />
                                            <ObjectStatus text="{dashboard>procurementStatus}" state="{dashboard>procurementStatusState}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </ScrollContainer>
                    </VBox>
                </VBox>

                <VBox class="nxMmPurchCasePane" renderType="Bare">
                    <VBox class="nxMmPurchasingCard nxMmPurchCaseCard">
                        <HBox class="nxMmPurchasingCardHead" alignItems="Center" justifyContent="SpaceBetween">
                            <VBox>
                                <Title text="Selected Procurement Case" level="H5" />
                                <Text text="선택 구매 케이스" class="nxMmPurchasingCardSub" />
                            </VBox>
                            <VBox class="nxMmPurchasingCardIconWrap nxMmPurchasingCardIconWrap--detail">
                                <core:Icon src="sap-icon://case" size="1.1rem" color="#FFFFFF" />
                            </VBox>
                        </HBox>

                        <VBox visible="{= !${dashboard>/mmPurchasing/detail/hasSelection} }" class="nxMmPurchasingDetailEmpty" alignItems="Center" justifyContent="Center">
                            <core:Icon src="sap-icon://customer-order-entry" size="2rem" color="#9CA3AF" class="sapUiSmallMarginBottom" />
                            <Text text="{dashboard>/mmPurchasing/detail/emptyMessage}" class="nxMmPurchasingDetailEmptyText" />
                        </VBox>

                        <VBox visible="{dashboard>/mmPurchasing/detail/hasSelection}" class="nxMmPurchasingDetailBody" width="100%">
                            <HBox alignItems="Start" justifyContent="SpaceBetween" class="nxMmPurchasingDetailHead">
                                <VBox>
                                    <Text text="{dashboard>/mmPurchasing/detail/poNo}" class="nxMmPurchasingDetailPoNo" />
                                    <Text text="{dashboard>/mmPurchasing/detail/materialNo}" class="nxMmPurchasingDetailMatNo" />
                                </VBox>
                                <ObjectStatus text="{dashboard>/mmPurchasing/detail/status}" state="{dashboard>/mmPurchasing/detail/statusState}" />
                            </HBox>

                            <MessageStrip text="{dashboard>/mmPurchasing/detail/warningMessage}" type="Warning" showIcon="true"
                                visible="{= !!${dashboard>/mmPurchasing/detail/warningMessage} }" class="nxMmPurchasingDetailStrip" />
                            <MessageStrip text="{dashboard>/mmPurchasing/detail/successMessage}" type="Success" showIcon="true"
                                visible="{= !!${dashboard>/mmPurchasing/detail/successMessage} }" class="nxMmPurchasingDetailStrip" />

                            <VBox class="nxMmPurchCaseTiles" width="100%">
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="MIGO Document No" class="nxMmPurchasingDetailTileLabel" />
                                    <Text text="{dashboard>/mmPurchasing/detail/migoDoc}" class="nxMmPurchasingDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="PO Linked" class="nxMmPurchasingDetailTileLabel" />
                                    <ObjectStatus text="{dashboard>/mmPurchasing/detail/poLinked}" state="{dashboard>/mmPurchasing/detail/poLinkedState}" />
                                </VBox>
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="MIGO Linked" class="nxMmPurchasingDetailTileLabel" />
                                    <ObjectStatus text="{dashboard>/mmPurchasing/detail/migoLinked}" state="{dashboard>/mmPurchasing/detail/migoLinkedState}" />
                                </VBox>
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="Material Risk" class="nxMmPurchasingDetailTileLabel" />
                                    <ObjectStatus text="{dashboard>/mmPurchasing/detail/materialRisk}" state="{dashboard>/mmPurchasing/detail/materialRiskState}" />
                                </VBox>
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="Stock Qty" class="nxMmPurchasingDetailTileLabel" />
                                    <Text text="{dashboard>/mmPurchasing/detail/stockQty}" class="nxMmPurchasingDetailTileValue" />
                                </VBox>
                                <VBox class="nxMmPurchCaseTile">
                                    <Text text="Shortage Qty" class="nxMmPurchasingDetailTileLabel" />
                                    <Text text="{dashboard>/mmPurchasing/detail/shortageQty}" class="nxMmPurchasingDetailTileValue nxMmPurchasingDetailTileValue--danger" />
                                </VBox>
                            </VBox>

                            <VBox class="nxMmPurchasingDetailFillSection">
                                <HBox alignItems="Center" justifyContent="SpaceBetween">
                                    <Text text="Fill Rate" class="nxMmPurchasingDetailFillLabel" />
                                    <Text text="{dashboard>/mmPurchasing/detail/fillRate}" class="nxMmPurchasingDetailFillValue" />
                                </HBox>
                                <ProgressIndicator
                                    percentValue="{dashboard>/mmPurchasing/detail/fillRatePercent}"
                                    displayValue="{dashboard>/mmPurchasing/detail/fillRate}"
                                    state="{dashboard>/mmPurchasing/detail/fillRateState}"
                                    width="100%"
                                    class="nxMmPurchasingDetailFillBar" />
                            </VBox>

                            <HBox alignItems="Center" class="nxMmPurchasingDetailSourceRow">
                                <core:Icon src="sap-icon://database" size="0.75rem" color="#9CA3AF" class="sapUiTinyMarginEnd" />
                                <Text text="{dashboard>/mmPurchasing/detail/dataSource}" class="nxMmPurchasingDetailSource" />
                            </HBox>
                            <Text text="{dashboard>/mmPurchasing/detail/footerNote}" class="nxMmPurchasingDetailFooterNote" />
                        </VBox>
                    </VBox>
                </VBox>
            </HBox>

            <VBox class="nxMmPurchInsightPanel" width="100%" renderType="Bare">
                <HBox class="nxMmPurchInsightHead" alignItems="Center" justifyContent="SpaceBetween" width="100%">
                    <VBox>
                        <Title text="Purchasing Insight" level="H5" />
                        <Text text="PO/MIGO 연결 · 조달 리스크 · 데이터 가용성" class="nxMmPurchasingAnalysisSub" />
                    </VBox>
                    <ObjectStatus text="구매 연결 중심" state="Information" icon="sap-icon://bar-chart" />
                </HBox>
                <HBox class="nxMmPurchInsightGrid" wrap="Wrap" width="100%" items="{dashboard>/mmPurchasing/analysisCards}">
                    <items>
                        <VBox class="{= 'nxMmPurchInsightCard nxMmPurchInsightCard--' + ${dashboard>cardKey} }" renderType="Bare">
                            <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxMmPurchInsightCardHead">
                                <VBox>
                                    <Title text="{dashboard>title}" level="H5" />
                                    <Text text="{dashboard>subtitle}" class="nxMmPurchasingCardSub" />
                                </VBox>
                                <core:Icon src="{dashboard>icon}" size="1rem" color="#0070F2" />
                            </HBox>
                            <VBox class="nxMmPurchInsightBody" width="100%">
                                <core:HTML content="{dashboard>html}" />
                            </VBox>
                        </VBox>
                    </items>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
