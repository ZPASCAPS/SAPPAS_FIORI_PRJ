<!--
  DashboardCanvas.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardCanvas
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas

  역할:
  - 중앙 대시보드 본문. navKey에 따라 콘텐츠를 전환한다.
  - DASHBOARD: A공간 + B공간
  - MM_MATERIALS: MmCockpit (Controller에서 지연 로드)
  - 그 외 모듈: SectionPlaceholder
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    height="100%"
    width="100%">

    <VBox class="nxDashboardCanvasRoot" height="100%" width="100%" renderType="Bare">
        <HBox
            class="nxDashboardSplit"
            visible="{= ${dashboard>/ui/navKey} === 'DASHBOARD' }"
            height="100%"
            width="100%"
            renderType="Bare">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.OrderInquiry"
                class="nxSpaceA" />
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.E2EProcessFlow"
                class="nxSpaceB" />
        </HBox>

        <ScrollContainer
            id="mmCockpitScroll"
            class="nxContentScroll nxModuleCanvas nxMmCockpitCanvas"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox id="mmCockpitHost" class="nxContent nxModuleCanvasBody" width="100%" renderType="Bare" />
        </ScrollContainer>

        <ScrollContainer
            class="nxContentScroll nxModuleCanvas"
            visible="{= ${dashboard>/ui/navKey} !== 'DASHBOARD' &amp;&amp; ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox class="nxContent nxModuleCanvasBody" width="100%">
                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
            </VBox>
        </ScrollContainer>
    </VBox>
</mvc:View>
