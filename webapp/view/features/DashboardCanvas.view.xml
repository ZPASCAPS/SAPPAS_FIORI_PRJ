<!--
  DashboardCanvas.view.xml
  SD Overview: SdMain | MM Overview: MmOverview | MM Inventory: MmInventory | MM Purchasing: MmPurchasing | MM Goods Movement: blank | Reports: MmReports
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    height="100%"
    width="100%">

    <VBox class="nxDashboardCanvasRoot" height="100%" width="100%" renderType="Bare">
        <HBox
            class="nxDashboardSplit"
            visible="{= ${dashboard>/ui/navKey} === 'DASHBOARD' }"
            height="100%"
            width="100%"
            renderType="Bare">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.OrderInquiry"
                class="nxSpaceA" />
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.E2EProcessFlow"
                class="nxSpaceB" />
        </HBox>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxSdMainScroll"
            visible="{= ${dashboard>/ui/navKey} === 'SD_SALES' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="false"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.sd.SdMain"
                width="100%"
                height="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll"
            visible="{= (${dashboard>/ui/navKey} === 'PP_PRODUCTION' || ${dashboard>/ui/navKey} === 'FI_CO_FINANCE') &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox width="100%" renderType="Bare" class="nxModuleOverviewBody sapUiSmallMargin">
                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
            </VBox>
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmOverviewScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.MmOverview"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmInventoryScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'INVENTORY' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.MmInventory"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmPurchasingScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'PURCHASING' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.MmPurchasing"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmGoodsMovementScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'GOODS_MOVEMENT' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.MmGoodsMovement"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxContentScroll nxModuleCanvas"
            visible="{= (${dashboard>/ui/navKey} === 'SD_SALES' || ${dashboard>/ui/navKey} === 'PP_PRODUCTION' || ${dashboard>/ui/navKey} === 'FI_CO_FINANCE') &amp;&amp; ${dashboard>/moduleView/activeSubTab} !== 'OVERVIEW' || (${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'REPORTS') }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox class="nxContent nxModuleCanvasBody nxModuleContentBody" width="100%">
                <mvc:XMLView
                    viewName="com.capstone.dashboard.fioridashboard.view.features.MmReports"
                    visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'REPORTS' }"
                    width="100%" />
                <VBox
                    visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
                    width="100%">
                    <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
                </VBox>
            </VBox>
        </ScrollContainer>

        <ScrollContainer
            class="nxContentScroll nxModuleCanvas"
            visible="{= ${dashboard>/ui/navKey} !== 'DASHBOARD' &amp;&amp; ${dashboard>/ui/navKey} !== 'SD_SALES' &amp;&amp; ${dashboard>/ui/navKey} !== 'MM_MATERIALS' &amp;&amp; ${dashboard>/ui/navKey} !== 'PP_PRODUCTION' &amp;&amp; ${dashboard>/ui/navKey} !== 'FI_CO_FINANCE' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox class="nxContent nxModuleCanvasBody" width="100%">
                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
            </VBox>
        </ScrollContainer>
    </VBox>
</mvc:View>
