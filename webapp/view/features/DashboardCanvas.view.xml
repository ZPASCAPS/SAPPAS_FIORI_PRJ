<!--
  DashboardCanvas.view.xml
  SD: SdMain
  MM: MmOverview | MmInventory | MmPurchasing
  FI: FiOverview | FiGeneralLedger | FiAccountsPayable
  메모장: DashboardHeader → NotesPanel (오버레이)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    height="100%"
    width="100%">

    <VBox class="nxDashboardCanvasRoot" height="100%" width="100%" renderType="Bare">
        <HBox
            class="nxDashboardSplit"
            visible="{= ${dashboard>/ui/navKey} === 'DASHBOARD' }"
            height="100%"
            width="100%"
            renderType="Bare">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.OrderInquiry"
                class="nxSpaceA" />
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.E2EProcessFlow"
                class="nxSpaceB" />
        </HBox>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxSdMainScroll"
            visible="{= ${dashboard>/ui/navKey} === 'SD_SALES' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="false"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.sd.SdMain"
                width="100%"
                height="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll"
            visible="{= ${dashboard>/ui/navKey} === 'PP_PRODUCTION' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox width="100%" renderType="Bare" class="nxModuleOverviewBody sapUiSmallMargin">
                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
            </VBox>
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmOverviewScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmOverview"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxFiOverviewScroll"
            visible="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.FiOverview"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmInventoryScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'INVENTORY' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmInventory"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxFiGeneralLedgerScroll"
            visible="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'GENERAL_LEDGER' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.FiGeneralLedger"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmPurchasingScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'PURCHASING' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmPurchasing"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxFiAccountsPayableScroll"
            visible="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'ACCOUNTS_PAYABLE' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.FiAccountsPayable"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmGoodsMovementScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'GOODS_MOVEMENT' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmGoodsMovement"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxFiAccountsReceivableScroll"
            visible="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'ACCOUNTS_RECEIVABLE' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.FiAccountsReceivable"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxMmReportsScroll"
            visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'REPORTS' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmReports"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxModuleOverviewFill nxModuleOverviewScroll nxFiReportScroll"
            visible="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/moduleView/activeSubTab} === 'REPORT' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.FiReport"
                width="100%" />
        </ScrollContainer>

        <ScrollContainer
            class="nxContentScroll nxModuleCanvas"
            visible="{= (${dashboard>/ui/navKey} === 'SD_SALES' || ${dashboard>/ui/navKey} === 'PP_PRODUCTION') &amp;&amp; ${dashboard>/moduleView/activeSubTab} !== 'OVERVIEW' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox class="nxContent nxModuleCanvasBody nxModuleContentBody" width="100%">
                <VBox
                    visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
                    width="100%">
                    <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
                </VBox>
            </VBox>
        </ScrollContainer>

        <ScrollContainer
            class="nxContentScroll nxModuleCanvas"
            visible="{= ${dashboard>/ui/navKey} !== 'DASHBOARD' &amp;&amp; ${dashboard>/ui/navKey} !== 'SD_SALES' &amp;&amp; ${dashboard>/ui/navKey} !== 'MM_MATERIALS' &amp;&amp; ${dashboard>/ui/navKey} !== 'PP_PRODUCTION' &amp;&amp; ${dashboard>/ui/navKey} !== 'FI_CO_FINANCE' }"
            vertical="true"
            horizontal="false"
            height="100%"
            width="100%">
            <VBox class="nxContent nxModuleCanvasBody" width="100%">
                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
            </VBox>
        </ScrollContainer>
    </VBox>
</mvc:View>
