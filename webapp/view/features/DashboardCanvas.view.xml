<!--
  DashboardCanvas.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardCanvas
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas

  역할:
  - 중앙 대시보드 본문. 사이드바 navKey에 따라 SectionPlaceholder 등 콘텐츠를 표시한다.

  대시보드 구조:
  Main → DashboardMain → DashboardCanvas (가장 큰 흰색 콘텐츠 영역)

  협업:
  - 탭별 실제 차트·KPI 추가 시 이 View에 mvc:XMLView를 연결한다.
  - 현재는 모든 탭이 SectionPlaceholder.view.xml 안내 화면을 사용한다.
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardCanvas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    height="100%"
    width="100%">

    <ScrollContainer
        class="nxContentScroll"
        vertical="true"
        horizontal="false"
        height="100%"
        width="100%">
        <VBox class="nxContent nxDashboardCanvas" width="100%">
            <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.SectionPlaceholder" />
        </VBox>
    </ScrollContainer>
</mvc:View>
