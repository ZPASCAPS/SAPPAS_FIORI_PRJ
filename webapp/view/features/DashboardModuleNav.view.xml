<!--
  DashboardModuleNav.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardModuleNav
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardModuleNav

  역할:
  - 상단 헤더 아래 모듈 탭 바: DASHBOARD / SD / MM / PP / FI.
  - MM Flyout: hover/click 시 내부 메뉴(Overview~Note) 카드형 Popover 표시.

  대시보드 구조:
  Main → DashboardMain → DashboardModuleNav (헤더 바로 아래)

  협업:
  - 탭 UI·활성 스타일 → 이 View
  - navKey 변경 → DashboardModuleNav.controller.js
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardModuleNav"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <HBox class="nxModuleNavBar moduleNavBar" width="100%" alignItems="Center">
        <VBox id="moduleNavTabsWrap" class="nxModuleNavTabsWrap moduleNavBarTrack">
            <HBox id="moduleNavTabsBar" class="nxModuleNavBarInner moduleNavBarInner" alignItems="Center">
                <Button
                    id="moduleNavDashboard"
                    text="Dashboard"
                    icon="sap-icon://bbyd-dashboard"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'DASHBOARD' ? 'nxModuleNavTab nxModuleNavTabActive moduleNavItem moduleNavItemActive' : 'nxModuleNavTab moduleNavItem' }">
                    <customData>
                        <core:CustomData key="navKey" value="DASHBOARD" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavSd"
                    text="SD"
                    icon="sap-icon://sales-order"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'SD_SALES' ? 'nxModuleNavTab nxModuleNavTabActive moduleNavItem moduleNavItemActive' : 'nxModuleNavTab moduleNavItem' }">
                    <customData>
                        <core:CustomData key="navKey" value="SD_SALES" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavPp"
                    text="PP"
                    icon="sap-icon://factory"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'PP_PRODUCTION' ? 'nxModuleNavTab nxModuleNavTabActive moduleNavItem moduleNavItemActive' : 'nxModuleNavTab moduleNavItem' }">
                    <customData>
                        <core:CustomData key="navKey" value="PP_PRODUCTION" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavMm"
                    text="MM"
                    icon="sap-icon://product"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleNavTab nxModuleNavTabActive moduleNavItem moduleNavItemActive' : 'nxModuleNavTab moduleNavItem' }">
                    <customData>
                        <core:CustomData key="navKey" value="MM_MATERIALS" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavFi"
                    text="FI"
                    icon="sap-icon://money-bills"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' ? 'nxModuleNavTab nxModuleNavTabActive moduleNavItem moduleNavItemActive' : 'nxModuleNavTab moduleNavItem' }">
                    <customData>
                        <core:CustomData key="navKey" value="FI_CO_FINANCE" />
                    </customData>
                </Button>
            </HBox>
        </VBox>
    </HBox>

    <Popover
        id="moduleFlyoutPopover"
        class="moduleFlyoutPopover"
        showHeader="false"
        showArrow="true"
        placement="Bottom"
        offsetX="0"
        offsetY="4"
        contentWidth="13.5rem">
        <VBox id="moduleFlyoutBox" class="moduleFlyoutBox" width="100%" items="{dashboard>/ui/moduleFlyoutMenu}">
            <items>
                <Button
                    text="{dashboard>text}"
                    type="Transparent"
                    press=".onFlyoutItemPress"
                    width="100%"
                    class="{= ${dashboard>/ui/navKey} === ${dashboard>/ui/moduleFlyoutNavKey} &amp;&amp; ${dashboard>/moduleView/activeSubTab} === ${dashboard>key} ? 'moduleFlyoutItem moduleFlyoutItemActive' : 'moduleFlyoutItem' }" />
            </items>
        </VBox>
    </Popover>
</mvc:View>
