<!--
  DashboardModuleNav.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardModuleNav
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardModuleNav

  역할:
  - 상단 헤더 아래 모듈 탭 바: DASHBOARD / SD / MM / PP / FI.
  - 활성 탭 슬라이딩 밑줄 (Overview 서브탭과 동일 패턴)

  대시보드 구조:
  Main → DashboardMain → DashboardModuleNav (헤더 바로 아래)

  협업:
  - 탭 UI·활성 스타일 → 이 View
  - navKey 변경 → DashboardModuleNav.controller.js
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardModuleNav"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <HBox class="nxModuleNavBar" width="100%" alignItems="Center">
        <VBox id="moduleNavTabsWrap" class="nxModuleNavTabsWrap">
            <HBox id="moduleNavTabsBar" class="nxModuleNavBarInner" alignItems="Center">
                <Button
                    id="moduleNavDashboard"
                    text="Dashboard"
                    icon="sap-icon://bbyd-dashboard"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'DASHBOARD' ? 'nxModuleNavTab nxModuleNavTabActive' : 'nxModuleNavTab' }">
                    <customData>
                        <core:CustomData key="navKey" value="DASHBOARD" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavSd"
                    text="SD"
                    icon="sap-icon://sales-order"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'SD_SALES' ? 'nxModuleNavTab nxModuleNavTabActive' : 'nxModuleNavTab' }">
                    <customData>
                        <core:CustomData key="navKey" value="SD_SALES" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavMm"
                    text="MM"
                    icon="sap-icon://product"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleNavTab nxModuleNavTabActive' : 'nxModuleNavTab' }">
                    <customData>
                        <core:CustomData key="navKey" value="MM_MATERIALS" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavPp"
                    text="PP"
                    icon="sap-icon://factory"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'PP_PRODUCTION' ? 'nxModuleNavTab nxModuleNavTabActive' : 'nxModuleNavTab' }">
                    <customData>
                        <core:CustomData key="navKey" value="PP_PRODUCTION" />
                    </customData>
                </Button>
                <Button
                    id="moduleNavFi"
                    text="FI"
                    icon="sap-icon://money-bills"
                    type="Transparent"
                    press=".onModuleNavPress"
                    class="{= ${dashboard>/ui/navKey} === 'FI_CO_FINANCE' ? 'nxModuleNavTab nxModuleNavTabActive' : 'nxModuleNavTab' }">
                    <customData>
                        <core:CustomData key="navKey" value="FI_CO_FINANCE" />
                    </customData>
                </Button>
            </HBox>
        </VBox>
    </HBox>
</mvc:View>
