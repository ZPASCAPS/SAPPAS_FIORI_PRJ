<!--
  MmNotes.view.xml — MM 업무 노트 (LocalStorage, OData 미사용)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.MmNotes"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="mmNotesPage mmNotesShell mmNotesPanelMode" width="100%" renderType="Bare" alignItems="Stretch">
        <VBox class="mmNotesWorkspace" width="100%" renderType="Bare">
            <HBox class="mmNotesHeader" width="100%" alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center" class="mmNotesHeaderText" renderType="Bare">
                    <core:Icon src="sap-icon://notes" size="1.35rem" class="mmNotesHeaderIcon" color="#374151" />
                    <Title text="메모장" level="H3" class="mmNotesHeaderTitle" />
                    <Text
                        text="공유"
                        visible="{mmNotes>/isSharedStorage}"
                        class="mmNotesSharedBadge" />
                </HBox>
                <VBox id="mmNotesModuleTabsWrap" class="nxModuleSubTabsWrap mmNotesModuleTabsWrap" width="auto" renderType="Bare">
                    <HBox class="nxModuleSubTabs mmNotesModuleTabs" alignItems="Center" renderType="Bare">
                        <Button
                            id="mmNotesModuleTabSD"
                            text="SD"
                            type="Transparent"
                            press=".onModuleTabPress"
                            class="{= ${mmNotes>/activeModule} === 'SD' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                            <customData><core:CustomData key="moduleKey" value="SD" /></customData>
                        </Button>
                        <Button
                            id="mmNotesModuleTabPP"
                            text="PP"
                            type="Transparent"
                            press=".onModuleTabPress"
                            class="{= ${mmNotes>/activeModule} === 'PP' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                            <customData><core:CustomData key="moduleKey" value="PP" /></customData>
                        </Button>
                        <Button
                            id="mmNotesModuleTabMM"
                            text="MM"
                            type="Transparent"
                            press=".onModuleTabPress"
                            class="{= ${mmNotes>/activeModule} === 'MM' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                            <customData><core:CustomData key="moduleKey" value="MM" /></customData>
                        </Button>
                        <Button
                            id="mmNotesModuleTabFI"
                            text="FI"
                            type="Transparent"
                            press=".onModuleTabPress"
                            class="{= ${mmNotes>/activeModule} === 'FI' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                            <customData><core:CustomData key="moduleKey" value="FI" /></customData>
                        </Button>
                    </HBox>
                </VBox>
            </HBox>

            <HBox class="mmNotesBody" width="100%" renderType="Bare" alignItems="Stretch">
                <VBox class="mmNotesSidebar" width="100%" renderType="Bare">
                    <Text text="{mmNotes>/workspaceTitle}" class="mmNotesSidebarModuleLabel" />

                    <Button
                        text="새 페이지"
                        type="Transparent"
                        icon="sap-icon://add"
                        press=".onAddNote"
                        class="mmNotesAddButton"
                        width="100%" />

                    <List
                        id="mmNotesPageList"
                        mode="SingleSelectMaster"
                        includeItemInSelection="true"
                        selectionChange=".onSelectNote"
                        items="{mmNotes>/notes}"
                        visible="{mmNotes>/hasNotes}"
                        showSeparators="None"
                        class="mmNotesPageList"
                        width="100%">
                        <CustomListItem
                            type="Active"
                            class="{= ${mmNotes>id} === ${mmNotes>/selectedNoteId} ? 'mmNotesPageItem mmNotesPageItemSelected' : 'mmNotesPageItem' }">
                            <HBox
                                width="100%"
                                alignItems="Center"
                                justifyContent="SpaceBetween"
                                class="mmNotesPageItemRow"
                                renderType="Bare">
                                <VBox class="mmNotesPageItemInner" renderType="Bare">
                                    <Text text="{mmNotes>title}" class="mmNotesPageTitle" />
                                    <HBox
                                        alignItems="Center"
                                        class="mmNotesPageMetaRow"
                                        width="100%"
                                        renderType="Bare">
                                        <Text
                                            text="{mmNotes>updatedAtDisplay}"
                                            visible="{= ${mmNotes>updatedAtDisplay} !== '' }"
                                            class="mmNotesPageMeta" />
                                        <HBox
                                            alignItems="Center"
                                            visible="{= ${mmNotes>author} !== '' }"
                                            class="mmNotesPageAuthorBadge"
                                            renderType="Bare">
                                            <VBox
                                                alignItems="Center"
                                                justifyContent="Center"
                                                class="mmNotesPageAuthorAvatar"
                                                renderType="Bare">
                                                <Text text="{mmNotes>authorInitial}" class="mmNotesPageAuthorAvatarText" />
                                            </VBox>
                                            <Text text="{mmNotes>author}" class="mmNotesPageAuthorName" />
                                        </HBox>
                                    </HBox>
                                </VBox>
                                <HBox alignItems="Center" class="mmNotesPageItemActions" renderType="Bare">
                                    <Button
                                        icon="sap-icon://edit"
                                        type="Transparent"
                                        tooltip="이름 수정"
                                        press=".onEditNoteFromList"
                                        class="mmNotesPageItemActionBtn" />
                                    <Button
                                        icon="sap-icon://delete"
                                        type="Transparent"
                                        tooltip="삭제"
                                        press=".onDeleteNoteFromList"
                                        class="mmNotesPageItemActionBtn mmNotesPageItemDeleteBtn" />
                                </HBox>
                            </HBox>
                        </CustomListItem>
                    </List>

                    <VBox
                        visible="{= !${mmNotes>/hasNotes} }"
                        class="mmNotesSidebarEmpty"
                        alignItems="Center"
                        justifyContent="Center"
                        width="100%">
                        <core:Icon src="sap-icon://notes" size="1.75rem" color="#9CA3AF" />
                        <Text text="아직 작성된 노트가 없습니다." class="mmNotesEmptyTitle" />
                        <Text text="새 페이지를 추가해 업무 메모를 작성하세요." class="mmNotesEmptyHint" />
                    </VBox>
                </VBox>

                <VBox class="mmNotesEditor" width="100%" renderType="Bare">
                    <VBox
                        visible="{mmNotes>/hasSelectedNote}"
                        width="100%"
                        class="mmNotesEditorContent"
                        renderType="Bare">
                        <HBox class="mmNotesEditorTopBar" width="100%" alignItems="Center" justifyContent="SpaceBetween">
                            <Text
                                text="{= ${mmNotes>/workspaceTitle} + ' / ' + (${mmNotes>/selectedNote/section} || 'General') }"
                                class="mmNotesBreadcrumb" />
                            <HBox alignItems="Center" class="mmNotesActionBar" renderType="Bare">
                                <Button
                                    text="저장"
                                    type="Transparent"
                                    icon="sap-icon://save"
                                    press=".onSaveNote"
                                    class="mmNotesSaveBtn mmNotesGhostBtn sapUiTinyMarginEnd" />
                                <Button
                                    text="삭제"
                                    type="Transparent"
                                    icon="sap-icon://delete"
                                    press=".onDeleteNote"
                                    class="mmNotesDeleteBtn mmNotesGhostBtn" />
                            </HBox>
                        </HBox>

                        <VBox class="mmNotesEditorCanvas" width="100%" renderType="Bare">
                            <Input
                                id="mmNotesTitleInput"
                                value="{mmNotes>/selectedNote/title}"
                                width="100%"
                                placeholder="제목 없음"
                                class="{= 'mmNotesTitleInput mmNotesFs-' + (${mmNotes>/selectedNote/fontSize} || '16') + ' mmNotesFf-' + (${mmNotes>/selectedNote/fontFamily} || 'default') }" />

                            <HBox class="mmNotesToolbar" alignItems="Center" wrap="Wrap" width="100%" renderType="Bare">
                                <HBox alignItems="Center" class="mmNotesToolbarGroup" renderType="Bare">
                                    <Select
                                        selectedKey="{mmNotes>/selectedNote/fontFamily}"
                                        forceSelection="true"
                                        change=".onFontSettingChange"
                                        class="mmNotesToolbarSelect"
                                        items="{mmNotes>/fontFamilyOptions}">
                                        <core:Item key="{mmNotes>key}" text="{mmNotes>text}" />
                                    </Select>
                                    <Select
                                        selectedKey="{mmNotes>/selectedNote/fontSize}"
                                        forceSelection="true"
                                        change=".onFontSettingChange"
                                        class="mmNotesToolbarSelect mmNotesToolbarSelect--size"
                                        items="{mmNotes>/fontSizeOptions}">
                                        <core:Item key="{mmNotes>key}" text="{mmNotes>text}" />
                                    </Select>
                                </HBox>
                            </HBox>

                            <HBox class="mmNotesMetaChips" alignItems="Center" wrap="Wrap" width="100%" renderType="Bare">
                                <HBox alignItems="Center" class="mmNotesMetaChip" renderType="Bare">
                                    <Text text="{mmNotes>/activeModule}" class="mmNotesMetaChipText" />
                                </HBox>
                                <HBox alignItems="Center" class="mmNotesMetaChip mmNotesMetaChip--select" renderType="Bare">
                                    <Select
                                        selectedKey="{mmNotes>/selectedNote/section}"
                                        forceSelection="true"
                                        class="mmNotesMetaChipSelect"
                                        items="{mmNotes>/sectionOptions}">
                                        <core:Item key="{mmNotes>key}" text="{mmNotes>text}" />
                                    </Select>
                                </HBox>
                                <HBox
                                    alignItems="Center"
                                    class="mmNotesMetaChip mmNotesMetaChip--author mmNotesMetaChip--authorSelect"
                                    renderType="Bare">
                                    <VBox
                                        alignItems="Center"
                                        justifyContent="Center"
                                        class="mmNotesEditorAuthorAvatar"
                                        renderType="Bare">
                                        <Text text="{mmNotes>/selectedNote/authorInitial}" class="mmNotesEditorAuthorAvatarText" />
                                    </VBox>
                                    <Select
                                        id="mmNotesAuthorSelect"
                                        selectedKey="{mmNotes>/selectedNote/author}"
                                        forceSelection="false"
                                        change=".onAuthorSelectChange"
                                        class="mmNotesMetaChipSelect mmNotesMetaChipSelect--author"
                                        items="{mmNotes>/authorOptions}">
                                        <core:Item key="{mmNotes>name}" text="{mmNotes>name}" />
                                    </Select>
                                </HBox>
                                <HBox
                                    alignItems="Center"
                                    visible="{= ${mmNotes>/selectedNote/updatedAt} !== '' }"
                                    class="mmNotesMetaChip mmNotesMetaChip--muted"
                                    renderType="Bare">
                                    <Text text="{mmNotes>/selectedNote/updatedAtDisplay}" class="mmNotesMetaChipText mmNotesMetaChipMuted" />
                                </HBox>
                            </HBox>

                            <TextArea
                                value="{mmNotes>/selectedNote/content}"
                                width="100%"
                                rows="22"
                                growing="true"
                                growingMaxLines="32"
                                placeholder="내용을 입력하세요. 업무 확인 사항, 체크리스트, 메모를 자유롭게 작성할 수 있습니다."
                                class="{= 'mmNotesContentArea mmNotesFs-' + (${mmNotes>/selectedNote/fontSize} || '16') + ' mmNotesFf-' + (${mmNotes>/selectedNote/fontFamily} || 'default') }" />
                        </VBox>
                    </VBox>

                    <VBox
                        visible="{= !${mmNotes>/hasSelectedNote} }"
                        class="mmNotesEditorEmpty"
                        alignItems="Center"
                        justifyContent="Center"
                        width="100%">
                        <VBox
                            alignItems="Center"
                            justifyContent="Center"
                            class="mmNotesEditorEmptyIllustration sapUiMediumMarginBottom">
                            <core:Icon src="sap-icon://notes" size="2.75rem" color="#0D9488" />
                        </VBox>
                        <Text text="페이지를 선택하거나 새 페이지를 추가하세요." class="mmNotesEmptyTitle mmNotesEmptyTitle--large" />
                        <Text text="업무 확인 사항을 페이지 단위로 기록할 수 있습니다." class="mmNotesEmptyHint" />
                        <Button
                            text="새 페이지"
                            type="Transparent"
                            icon="sap-icon://add"
                            press=".onAddNote"
                            class="mmNotesAddButton mmNotesAddButton--empty sapUiSmallMarginTop" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</mvc:View>
