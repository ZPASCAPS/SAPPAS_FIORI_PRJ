<!--
  MmOverview.view.xml — MM Overview Cockpit (SAP OData)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.MmOverview"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxMmOverview" width="100%" renderType="Bare">
        <MessageStrip
            text="{dashboard>/mmOverview/error}"
            type="Error"
            showIcon="true"
            visible="{= ${dashboard>/mmOverview/error} ? true : false }"
            class="sapUiSmallMarginBottom" />

        <HBox class="nxMmOverviewInfoBar" alignItems="Center" justifyContent="SpaceBetween">
            <Text text="{= '현재 조회 기준: ' + ${dashboard>/mmOverview/criteriaLabel} }" class="nxMmOverviewInfoText" />
            <HBox alignItems="Center">
                <core:Icon src="sap-icon://history" size="0.875rem" color="#0070F2" class="sapUiTinyMarginEnd" />
                <Text text="{= 'Last Updated: ' + ${dashboard>/mmOverview/lastUpdated} }" class="nxMmOverviewInfoMeta" />
            </HBox>
        </HBox>

        <BusyIndicator visible="{dashboard>/mmOverview/loading}" class="nxMmOverviewBusy" />

        <VBox visible="{= !${dashboard>/mmOverview/loading} }" width="100%" renderType="Bare" class="nxMmOverviewBody">
            <Text
                text="MM 담당자가 부족 자재, 재고 상태, PO/MIGO 추적 현황을 한눈에 확인하는 Cockpit 화면입니다."
                class="nxMmOverviewCockpitDesc" />

            <HBox class="nxMmOverviewKpiRow" wrap="Wrap" items="{dashboard>/mmOverview/primaryKpis}">
                <items>
                    <VBox class="{= 'nxMmOverviewKpiCard nxMmOverviewKpiCard--' + ${dashboard>accent} }">
                        <Text text="{dashboard>displayTitle}" class="nxMmOverviewKpiTitle" />
                        <HBox alignItems="Baseline" class="nxMmOverviewKpiValueRow">
                            <Text text="{dashboard>value}" class="nxMmOverviewKpiValue" />
                            <Text text="{dashboard>unit}" visible="{= !!${dashboard>unit} }" class="nxMmOverviewKpiUnit" />
                        </HBox>
                        <Text text="{dashboard>hint}" class="nxMmOverviewKpiHint" />
                    </VBox>
                </items>
            </HBox>

            <VBox items="{dashboard>/mmOverview/row1Charts}" class="nxMmOverviewChartGridInner" width="100%">
                <items>
                    <Panel class="nxMmOverviewCard nxMmOverviewChartCard">
                        <headerToolbar>
                            <Toolbar class="nxMmOverviewChartToolbar">
                                <Title text="{dashboard>title}" level="H5" class="nxMmOverviewChartTitle" />
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <VBox class="nxMmOverviewChartBody" width="100%">
                                <Text text="{dashboard>subtitle}" class="nxMmOverviewChartSub" />
                                <core:HTML content="{dashboard>html}" />
                            </VBox>
                        </content>
                    </Panel>
                </items>
            </VBox>

            <VBox items="{dashboard>/mmOverview/row2Charts}" class="nxMmOverviewChartGridInner" width="100%">
                <items>
                    <Panel class="nxMmOverviewCard nxMmOverviewChartCard">
                        <headerToolbar>
                            <Toolbar class="nxMmOverviewChartToolbar">
                                <Title text="{dashboard>title}" level="H5" class="nxMmOverviewChartTitle" />
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <VBox class="nxMmOverviewChartBody" width="100%">
                                <Text text="{dashboard>subtitle}" class="nxMmOverviewChartSub" />
                                <core:HTML content="{dashboard>html}" />
                            </VBox>
                        </content>
                    </Panel>
                </items>
            </VBox>

            <VBox visible="{dashboard>/mmOverview/hasExtraCharts}" width="100%" class="nxMmOverviewExtraChartsWrap">
                <HBox justifyContent="End" width="100%">
                    <Button
                        text="{= ${dashboard>/mmOverview/chartsExpanded} ? '분석 접기' : '분석 더보기' }"
                        type="Transparent"
                        icon="{= ${dashboard>/mmOverview/chartsExpanded} ? 'sap-icon://slim-arrow-up' : 'sap-icon://slim-arrow-down' }"
                        press=".onChartsTogglePress"
                        class="nxMmOverviewWorklistToggleBtn" />
                </HBox>
                <VBox
                    visible="{dashboard>/mmOverview/chartsExpanded}"
                    items="{dashboard>/mmOverview/extraCharts}"
                    class="nxMmOverviewChartGridInner nxMmOverviewChartGridExtra"
                    width="100%">
                    <items>
                        <Panel class="nxMmOverviewCard nxMmOverviewChartCard">
                            <headerToolbar>
                                <Toolbar class="nxMmOverviewChartToolbar">
                                    <Title text="{dashboard>title}" level="H5" class="nxMmOverviewChartTitle" />
                                </Toolbar>
                            </headerToolbar>
                            <content>
                                <VBox class="nxMmOverviewChartBody" width="100%">
                                    <Text text="{dashboard>subtitle}" class="nxMmOverviewChartSub" />
                                    <core:HTML content="{dashboard>html}" />
                                </VBox>
                            </content>
                        </Panel>
                    </items>
                </VBox>
            </VBox>

            <Panel class="nxMmOverviewCard nxMmOverviewWorklistPanel" width="100%">
                <headerToolbar>
                    <Toolbar class="nxMmOverviewWorklistToolbar">
                        <VBox class="nxMmOverviewWorklistTitleBlock">
                            <Title text="Operational Worklist" level="H5" class="nxMmOverviewWorklistTitle" />
                            <Text text="우선 확인 업무 목록" class="nxMmOverviewWorklistSub" />
                        </VBox>
                        <ToolbarSpacer />
                        <Text
                            text="{= ${dashboard>/mmOverview/worklistVisibleCount} + ' / ' + ${dashboard>/mmOverview/worklistTotalCount} + '건 표시' }"
                            class="nxMmOverviewWorklistCount" />
                    </Toolbar>
                </headerToolbar>
                <content>
                    <Table
                        id="mmOverviewWorklist"
                        items="{dashboard>/mmOverview/visibleWorklist}"
                        mode="SingleSelectMaster"
                        includeItemInSelection="true"
                        fixedLayout="Strict"
                        class="{= 'nxMmOverviewWorklistTable' + (${dashboard>/mmOverview/worklistExpanded} ? ' nxMmOverviewWorklistTableExpanded' : '') }">
                        <columns>
                            <Column width="4.5rem"><Text text="Type" /></Column>
                            <Column width="7rem"><Text text="Object No" /></Column>
                            <Column width="7rem"><Text text="Material" /></Column>
                            <Column><Text text="Info" /></Column>
                            <Column width="4.5rem" hAlign="End"><Text text="Status" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem type="Active" press=".onWorklistPress" class="nxMmOverviewWorklistRow">
                                <cells>
                                    <Text text="{dashboard>type}" class="nxMmOverviewWlEllipsis" />
                                    <Text text="{dashboard>subtitle}" class="nxMmOverviewWlEllipsis" />
                                    <Text text="{dashboard>subtitle}" class="nxMmOverviewWlEllipsis" />
                                    <Text text="{dashboard>info}" class="nxMmOverviewWlEllipsis" />
                                    <ObjectStatus text="{dashboard>type}" state="{dashboard>status}" class="nxMmOverviewWlStatus" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                    <HBox class="nxMmOverviewWorklistToggleRow" justifyContent="End" visible="{dashboard>/mmOverview/worklistShowToggle}">
                        <Button
                            text="{= '더보기 ' + ${dashboard>/mmOverview/worklistHiddenCount} + '건' }"
                            type="Transparent"
                            press=".onWorklistExpandPress"
                            visible="{= !${dashboard>/mmOverview/worklistExpanded} }"
                            class="nxMmOverviewWorklistToggleBtn" />
                        <Button
                            text="접기"
                            type="Transparent"
                            press=".onWorklistCollapsePress"
                            visible="{dashboard>/mmOverview/worklistExpanded}"
                            class="nxMmOverviewWorklistToggleBtn" />
                    </HBox>
                </content>
            </Panel>
        </VBox>
    </VBox>

    <Dialog
        id="mmOverviewDetailDialog"
        title="{dashboard>/mmOverview/detail/title}"
        contentWidth="24rem"
        draggable="true"
        resizable="true"
        class="nxMmOverviewDetailDialog">
        <content>
            <VBox items="{dashboard>/mmOverview/detail/fields}" width="100%" class="sapUiSmallMargin">
                <items>
                    <HBox class="nxMmOverviewDetailRow" alignItems="Start" justifyContent="SpaceBetween">
                        <Label text="{dashboard>label}" class="nxMmOverviewDetailLabel" />
                        <Text text="{dashboard>value}" class="nxMmOverviewDetailValue" />
                    </HBox>
                </items>
            </VBox>
        </content>
        <endButton>
            <Button text="닫기" press=".onDetailClose" />
        </endButton>
    </Dialog>
</mvc:View>
