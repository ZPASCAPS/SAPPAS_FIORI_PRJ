<!--
  DashboardToolbar.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.DashboardToolbar
  Controller: com.capstone.dashboard.fioridashboard.controller.features.DashboardToolbar

  역할:
  - 현재 탭 제목(navLabel), 기준 시각, 새로고침, 대시보드 설정 버튼 영역.

  대시보드 구조:
  Main → DashboardMain → DashboardToolbar (헤더 아래 회색 바)

  협업:
  - 타이틀·버튼 UI → 이 View
  - 새로고침 EventBus 발행 → DashboardToolbar.controller.js
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.DashboardToolbar"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <HBox class="nxWelcomeRow" width="100%" alignItems="Center" justifyContent="SpaceBetween">
        <HBox alignItems="Center" class="nxWelcomeLine" width="100%">
            <Text
                text="{dashboard>/ui/navLabel}"
                class="nxWelcomeText"
                wrapping="false" />
        </HBox>

        <HBox alignItems="Center" class="nxWelcomeActions">
            <Text text="{dashboard>/ui/lastUpdated}" class="nxLastUpdated" />
            <Button
                icon="sap-icon://refresh"
                type="Transparent"
                tooltip="새로고침"
                press=".onRefresh"
                class="nxWelcomeRefreshBtn" />
            <Button
                text="대시보드 설정"
                icon="sap-icon://grid"
                type="Transparent"
                press=".onDashboardSettings"
                class="nxSettingsBtn" />
        </HBox>
    </HBox>
</mvc:View>
