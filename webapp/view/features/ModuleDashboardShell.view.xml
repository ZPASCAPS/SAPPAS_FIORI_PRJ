<!--
  ModuleDashboardShell.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.ModuleDashboardShell
  Controller: com.capstone.dashboard.fioridashboard.controller.features.ModuleDashboardShell

  역할:
  - SD/MM/PP/FI 모듈 상단 CareOps Finances 레이아웃 (제목·서브탭·KPI).
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.ModuleDashboardShell"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="{= ${dashboard>/ui/navKey} === 'SD_SALES' ? 'nxModuleShell nxModuleShell--sd' : (${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleShell nxMmMaterialsShell' : (${dashboard>/ui/navKey} === 'FI_CO_FINANCE' ? 'nxModuleShell nxFiFinanceShell' : 'nxModuleShell')) }" width="100%">
        <VBox class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleShellTop nxMmMaterialsTop' : (${dashboard>/ui/navKey} === 'FI_CO_FINANCE' ? 'nxModuleShellTop nxFiFinanceTop' : 'nxModuleShellTop') }" width="100%" visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' &amp;&amp; ${dashboard>/ui/navKey} !== 'FI_CO_FINANCE' }">
            <HBox class="nxModuleShellHeader" width="100%" alignItems="Center" justifyContent="SpaceBetween" visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' &amp;&amp; ${dashboard>/ui/navKey} !== 'FI_CO_FINANCE' }">
                <HBox class="nxModuleShellHeaderLeft" alignItems="Center" renderType="Bare">
                    <Title text="{dashboard>/moduleView/title}" level="H2" class="nxModuleShellTitle" />
                    <Text
                        visible="{= ${dashboard>/ui/navKey} === 'SD_SALES' }"
                        text="수주·출하·여신·반품 현황을 한 화면에서 모니터링합니다."
                        class="nxSdShellDesc" />
                </HBox>
                <HBox alignItems="Center" class="nxModuleShellActions">
                    <Select
                        selectedKey="{dashboard>/moduleView/period}"
                        width="9.5rem"
                        forceSelection="true"
                        change=".onPeriodChange"
                        enabled="{= ${dashboard>/moduleView/activeSubTab} !== 'INVENTORY' &amp;&amp; ${dashboard>/moduleView/activeSubTab} !== 'PURCHASING' &amp;&amp; ${dashboard>/moduleView/activeSubTab} !== 'GOODS_MOVEMENT' }"
                        class="nxModulePeriodSelect"
                        items="{dashboard>/moduleView/periodOptions}">
                        <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                    </Select>
                    <Button
                        id="moduleSettingsBtn"
                        icon="sap-icon://action-settings"
                        type="Transparent"
                        tooltip="설정"
                        press=".onModuleSettings"
                        class="nxModuleSquareBtn" />
                </HBox>
            </HBox>

            <VBox id="moduleSubTabsWrap" class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleSubTabsWrap nxMmMaterialsSubTabsWrap mmSubNavBarWrap' : 'nxModuleSubTabsWrap' }" visible="{= ${dashboard>/ui/navKey} !== 'SD_SALES' }" width="100%">
            <HBox id="moduleSubTabsBar" class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleSubTabsBar mmSubNavBar' : 'nxModuleSubTabsBar' }" width="100%" alignItems="Center" justifyContent="SpaceBetween">
            <HBox class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? 'nxModuleSubTabs nxModuleSubTabsWork mmSubNavList' : 'nxModuleSubTabs nxModuleSubTabsWork' }" alignItems="Center" wrap="Wrap">
            <Button
                id="subTabOverview"
                text="Overview"
                type="Transparent"
                press=".onSubTabPress"
                class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? (${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' ? 'mmSubNavItem mmSubNavItemActive' : 'mmSubNavItem') : (${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab') }">
                <customData><core:CustomData key="subTabKey" value="OVERVIEW" /></customData>
            </Button>
            <Button
                id="subTabOperations"
                text="Operations"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'OPERATIONS' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                <customData><core:CustomData key="subTabKey" value="OPERATIONS" /></customData>
            </Button>
            <Button
                id="subTabDistribution"
                text="Source distribution"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'DISTRIBUTION' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                <customData><core:CustomData key="subTabKey" value="DISTRIBUTION" /></customData>
            </Button>
            <Button
                id="subTabInsurance"
                text="Insurance"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} !== 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'INSURANCE' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab' }">
                <customData><core:CustomData key="subTabKey" value="INSURANCE" /></customData>
            </Button>
            <Button
                id="subTabMmInventory"
                text="Inventory"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'INVENTORY' ? 'mmSubNavItem mmSubNavItemActive' : 'mmSubNavItem' }">
                <customData><core:CustomData key="subTabKey" value="INVENTORY" /></customData>
            </Button>
            <Button
                id="subTabMmPurchasing"
                text="Purchasing"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'PURCHASING' ? 'mmSubNavItem mmSubNavItemActive' : 'mmSubNavItem' }">
                <customData><core:CustomData key="subTabKey" value="PURCHASING" /></customData>
            </Button>
            <Button
                id="subTabMmGoodsMovement"
                text="Goods Movement"
                type="Transparent"
                press=".onSubTabPress"
                visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' }"
                class="{= ${dashboard>/moduleView/activeSubTab} === 'GOODS_MOVEMENT' ? 'mmSubNavItem mmSubNavItemActive' : 'mmSubNavItem' }">
                <customData><core:CustomData key="subTabKey" value="GOODS_MOVEMENT" /></customData>
            </Button>
            <Button
                id="subTabReports"
                text="Reports"
                type="Transparent"
                press=".onSubTabPress"
                class="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' ? (${dashboard>/moduleView/activeSubTab} === 'REPORTS' ? 'mmSubNavItem mmSubNavItemActive' : 'mmSubNavItem') : (${dashboard>/moduleView/activeSubTab} === 'REPORTS' ? 'nxModuleSubTab nxModuleSubTabActive' : 'nxModuleSubTab') }">
                <customData><core:CustomData key="subTabKey" value="REPORTS" /></customData>
            </Button>
            </HBox>

            <HBox alignItems="Center" class="nxMmMaterialsRightGroup mmSubNavNoteZone" visible="{= ${dashboard>/ui/navKey} === 'MM_MATERIALS' }">
                <HBox alignItems="Center" class="nxMmMaterialsActions" visible="false">
                    <Button
                        id="mmInventoryFilterBtn"
                        text="조회/필터"
                        icon="sap-icon://filter"
                        type="Transparent"
                        press=".onMmInventoryFilterOpen"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'INVENTORY' }"
                        class="nxModuleFilterBtn sapUiTinyMarginEnd" />
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        tooltip="SAP 새로고침"
                        press=".onMmInventoryRefresh"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'INVENTORY' }"
                        class="nxModuleSquareBtn sapUiTinyMarginEnd" />
                    <Button
                        id="mmPurchasingFilterBtn"
                        text="조회/필터"
                        icon="sap-icon://filter"
                        type="Transparent"
                        press=".onMmPurchasingFilterOpen"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'PURCHASING' }"
                        class="nxModuleFilterBtn sapUiTinyMarginEnd" />
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        tooltip="SAP 새로고침"
                        press=".onMmPurchasingRefresh"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'PURCHASING' }"
                        class="nxModuleSquareBtn sapUiTinyMarginEnd" />
                    <Button
                        id="mmGoodsMovementFilterBtn"
                        text="조회/필터"
                        icon="sap-icon://filter"
                        type="Transparent"
                        press=".onMmGoodsMovementFilterOpen"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'GOODS_MOVEMENT' }"
                        class="nxModuleFilterBtn sapUiTinyMarginEnd" />
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        tooltip="SAP 새로고침"
                        press=".onMmGoodsMovementRefresh"
                        visible="{= ${dashboard>/moduleView/activeSubTab} === 'GOODS_MOVEMENT' }"
                        class="nxModuleSquareBtn sapUiTinyMarginEnd" />
                </HBox>
            </HBox>
            </HBox>
            </VBox>
        </VBox>

        <VBox
            class="nxModuleShellKpiBand"
            width="100%"
            visible="{= ${dashboard>/moduleView/activeSubTab} === 'OVERVIEW' &amp;&amp; ${dashboard>/ui/navKey} !== 'MM_MATERIALS' &amp;&amp; ${dashboard>/ui/navKey} !== 'FI_CO_FINANCE' &amp;&amp; ${dashboard>/ui/navKey} !== 'SD_SALES' }">
            <HBox class="nxModuleKpiRow" width="100%" alignItems="Stretch">
            <VBox class="nxModuleKpiCard">
                <Text text="{dashboard>/moduleView/kpis/0/label}" class="nxModuleKpiLabel" />
                <HBox alignItems="Baseline" class="nxModuleKpiValueRow">
                    <Text text="{dashboard>/moduleView/kpis/0/valueMain}" class="nxModuleKpiValueMain" />
                    <Text text="{dashboard>/moduleView/kpis/0/valueSuffix}" class="nxModuleKpiValueSuffix" />
                </HBox>
                <HBox alignItems="Center" class="nxModuleKpiTrendRow" visible="{= ${dashboard>/moduleView/settings/showKpiTrends} !== false }">
                    <Text text="{dashboard>/moduleView/kpis/0/trendHint}" class="nxModuleKpiTrendHint" />
                    <HBox alignItems="Center" class="{= ${dashboard>/moduleView/kpis/0/trendUp} ? 'nxModuleKpiTrend nxModuleKpiTrendUp' : 'nxModuleKpiTrend nxModuleKpiTrendDown' }">
                        <core:Icon src="{= ${dashboard>/moduleView/kpis/0/trendUp} ? 'sap-icon://trend-up' : 'sap-icon://trend-down' }" size="0.75rem" class="nxModuleKpiTrendIcon" />
                        <Text text="{dashboard>/moduleView/kpis/0/trend}" class="nxModuleKpiTrendText" />
                    </HBox>
                </HBox>
            </VBox>
            <VBox class="nxModuleKpiCard">
                <Text text="{dashboard>/moduleView/kpis/1/label}" class="nxModuleKpiLabel" />
                <HBox alignItems="Baseline" class="nxModuleKpiValueRow">
                    <Text text="{dashboard>/moduleView/kpis/1/valueMain}" class="nxModuleKpiValueMain" />
                    <Text text="{dashboard>/moduleView/kpis/1/valueSuffix}" class="nxModuleKpiValueSuffix" />
                </HBox>
                <HBox alignItems="Center" class="nxModuleKpiTrendRow" visible="{= ${dashboard>/moduleView/settings/showKpiTrends} !== false }">
                    <Text text="{dashboard>/moduleView/kpis/1/trendHint}" class="nxModuleKpiTrendHint" />
                    <HBox alignItems="Center" class="{= ${dashboard>/moduleView/kpis/1/trendUp} ? 'nxModuleKpiTrend nxModuleKpiTrendUp' : 'nxModuleKpiTrend nxModuleKpiTrendDown' }">
                        <core:Icon src="{= ${dashboard>/moduleView/kpis/1/trendUp} ? 'sap-icon://trend-up' : 'sap-icon://trend-down' }" size="0.75rem" class="nxModuleKpiTrendIcon" />
                        <Text text="{dashboard>/moduleView/kpis/1/trend}" class="nxModuleKpiTrendText" />
                    </HBox>
                </HBox>
            </VBox>
            <VBox class="nxModuleKpiCard">
                <Text text="{dashboard>/moduleView/kpis/2/label}" class="nxModuleKpiLabel" />
                <HBox alignItems="Baseline" class="nxModuleKpiValueRow">
                    <Text text="{dashboard>/moduleView/kpis/2/valueMain}" class="nxModuleKpiValueMain" />
                    <Text text="{dashboard>/moduleView/kpis/2/valueSuffix}" class="nxModuleKpiValueSuffix" />
                </HBox>
                <HBox alignItems="Center" class="nxModuleKpiTrendRow" visible="{= ${dashboard>/moduleView/settings/showKpiTrends} !== false }">
                    <Text text="{dashboard>/moduleView/kpis/2/trendHint}" class="nxModuleKpiTrendHint" />
                    <HBox alignItems="Center" class="{= ${dashboard>/moduleView/kpis/2/trendUp} ? 'nxModuleKpiTrend nxModuleKpiTrendUp' : 'nxModuleKpiTrend nxModuleKpiTrendDown' }">
                        <core:Icon src="{= ${dashboard>/moduleView/kpis/2/trendUp} ? 'sap-icon://trend-up' : 'sap-icon://trend-down' }" size="0.75rem" class="nxModuleKpiTrendIcon" />
                        <Text text="{dashboard>/moduleView/kpis/2/trend}" class="nxModuleKpiTrendText" />
                    </HBox>
                </HBox>
            </VBox>
            <VBox class="nxModuleKpiCard nxModuleKpiCardLast">
                <Text text="{dashboard>/moduleView/kpis/3/label}" class="nxModuleKpiLabel" />
                <HBox alignItems="Baseline" class="nxModuleKpiValueRow">
                    <Text text="{dashboard>/moduleView/kpis/3/valueMain}" class="nxModuleKpiValueMain" />
                    <Text text="{dashboard>/moduleView/kpis/3/valueSuffix}" class="nxModuleKpiValueSuffix" />
                </HBox>
                <HBox alignItems="Center" class="nxModuleKpiTrendRow" visible="{= ${dashboard>/moduleView/settings/showKpiTrends} !== false }">
                    <Text text="{dashboard>/moduleView/kpis/3/trendHint}" class="nxModuleKpiTrendHint" />
                    <HBox alignItems="Center" class="{= ${dashboard>/moduleView/kpis/3/trendUp} ? 'nxModuleKpiTrend nxModuleKpiTrendUp' : 'nxModuleKpiTrend nxModuleKpiTrendDown' }">
                        <core:Icon src="{= ${dashboard>/moduleView/kpis/3/trendUp} ? 'sap-icon://trend-up' : 'sap-icon://trend-down' }" size="0.75rem" class="nxModuleKpiTrendIcon" />
                        <Text text="{dashboard>/moduleView/kpis/3/trend}" class="nxModuleKpiTrendText" />
                    </HBox>
                </HBox>
            </VBox>
            </HBox>
        </VBox>
    </VBox>

    <Popover
        id="moduleSettingsPopover"
        placement="Bottom"
        contentWidth="22rem"
        showHeader="false"
        afterClose=".onModuleSettingsAfterClose"
        class="nxHeaderPopover nxModuleSettingsPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody">
                <VBox class="nxHeaderPopoverTitleRow">
                    <Title text="모듈 설정" level="H5" class="nxHeaderPopoverTitle" />
                </VBox>
                <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxSettingsRow">
                    <VBox class="nxSettingsRowText">
                        <Text text="KPI 추세 표시" class="nxSettingsLabel" />
                        <Text text="Overview KPI 카드 하단 추세" class="nxSettingsHint" />
                    </VBox>
                    <Switch state="{dashboard>/moduleView/settings/showKpiTrends}" change=".onShowKpiTrendsChange" />
                </HBox>
                <HBox alignItems="Center" justifyContent="SpaceBetween" class="nxSettingsRow">
                    <VBox class="nxSettingsRowText">
                        <Text text="내보내기에 추세 포함" class="nxSettingsLabel" />
                        <Text text="CSV 내보내기 시 추세 컬럼 포함" class="nxSettingsHint" />
                    </VBox>
                    <Switch state="{dashboard>/moduleView/settings/includeTrendsInExport}" change=".onIncludeTrendsInExportChange" />
                </HBox>
            </VBox>
        </content>
    </Popover>

    <Popover
        id="mmOverviewFilterPopover"
        placement="Bottom"
        contentWidth="30rem"
        showHeader="false"
        class="nxHeaderPopover nxMmOverviewFilterPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody nxMmOverviewFilterBody" renderType="Bare">
                <VBox class="nxHeaderPopoverTitleRow nxMmOverviewFilterHeader">
                    <Title text="조회 조건" level="H5" class="nxHeaderPopoverTitle" />
                    <Text text="Overview SAP 데이터 조회 기준을 설정합니다." class="nxMmOverviewFilterSubtitle" />
                </VBox>

                <VBox width="100%" class="nxMmOverviewFilterForm">
                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="조회 기준" class="nxMmOverviewFieldLabel" />
                        <SegmentedButton
                            id="mmOverviewFilterQueryMode"
                            selectedKey="{dashboard>/mmOverview/queryMode}"
                            selectionChange=".onMmOverviewFilterQueryModeChange"
                            width="100%"
                            class="nxMmOverviewFilterSegmented">
                            <items>
                                <SegmentedButtonItem key="ALL" text="전체" />
                                <SegmentedButtonItem key="MATERIAL" text="자재번호" />
                                <SegmentedButtonItem key="PO" text="PO번호" />
                            </items>
                        </SegmentedButton>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="검색어" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmOverview/searchText}"
                            placeholder="{dashboard>/mmOverview/searchPlaceholder}"
                            enabled="{dashboard>/mmOverview/searchEnabled}"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup nxMmOverviewFilterDisabledGroup">
                        <Label text="Plant" class="nxMmOverviewFieldLabel" />
                        <Input value="데이터 없음" enabled="false" width="100%" />
                        <Label text="Storage Location" class="nxMmOverviewFieldLabel nxMmOverviewFieldLabelSpaced" />
                        <Input value="데이터 없음" enabled="false" width="100%" />
                        <Text text="Plant·Storage Location은 현재 SAP OData 미제공 필드입니다." class="nxMmOverviewFilterDisabledHint" />
                    </VBox>
                </VBox>

                <HBox class="nxPopoverFooter nxMmOverviewFilterFooter" justifyContent="End" alignItems="Center" width="100%">
                    <Button text="초기화" type="Transparent" press=".onMmOverviewFilterReset" class="nxMmOverviewFilterResetBtn" />
                    <Button text="조회" type="Emphasized" press=".onMmOverviewFilterSearch" class="nxMmOverviewFilterSearchBtn" />
                </HBox>
            </VBox>
        </content>
    </Popover>

    <Popover
        id="mmInventoryFilterPopover"
        placement="Bottom"
        contentWidth="30rem"
        showHeader="false"
        class="nxHeaderPopover nxMmOverviewFilterPopover nxMmInventoryFilterPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody nxMmOverviewFilterBody" renderType="Bare">
                <VBox class="nxHeaderPopoverTitleRow nxMmOverviewFilterHeader">
                    <Title text="조회 조건" level="H5" class="nxHeaderPopoverTitle" />
                    <Text text="Inventory 자재별 재고 조회 기준을 설정합니다." class="nxMmOverviewFilterSubtitle" />
                </VBox>

                <VBox width="100%" class="nxMmOverviewFilterForm">
                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="자재번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmInventory/materialSearch}"
                            placeholder="자재번호 또는 자재명"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="Plant" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmInventory/plantFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmInventory/plantOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="Storage Location" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmInventory/storageLocationFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmInventory/storageLocationOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="Material Type" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmInventory/materialTypeFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmInventory/materialTypeOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>
                </VBox>

                <HBox class="nxPopoverFooter nxMmOverviewFilterFooter" justifyContent="End" alignItems="Center" width="100%">
                    <Button text="초기화" type="Transparent" press=".onMmInventoryFilterReset" class="nxMmOverviewFilterResetBtn" />
                    <Button text="조회" type="Emphasized" press=".onMmInventoryFilterSearch" class="nxMmOverviewFilterSearchBtn" />
                </HBox>
            </VBox>
        </content>
    </Popover>

    <Popover
        id="mmPurchasingFilterPopover"
        placement="Bottom"
        contentWidth="30rem"
        showHeader="false"
        class="nxHeaderPopover nxMmOverviewFilterPopover nxMmPurchasingFilterPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody nxMmOverviewFilterBody" renderType="Bare">
                <VBox class="nxHeaderPopoverTitleRow nxMmOverviewFilterHeader">
                    <Title text="조회 조건" level="H5" class="nxHeaderPopoverTitle" />
                    <Text text="Purchasing PO/MIGO Tracker 조회 기준을 설정합니다." class="nxMmOverviewFilterSubtitle" />
                </VBox>

                <VBox width="100%" class="nxMmOverviewFilterForm">
                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="PO 번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmPurchasing/poSearch}"
                            placeholder="PurchaseOrder"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="자재번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmPurchasing/materialSearch}"
                            placeholder="Material"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="MIGO 전표번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmPurchasing/migoSearch}"
                            placeholder="POMigoDoc / ProdMigoDoc"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="PO Linked" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmPurchasing/poLinkedFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmPurchasing/linkFilterOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="MIGO Linked" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmPurchasing/migoLinkedFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmPurchasing/linkFilterOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <CheckBox
                            text="부족 자재만 보기"
                            selected="{dashboard>/mmPurchasing/shortageOnly}" />
                    </VBox>
                </VBox>

                <HBox class="nxPopoverFooter nxMmOverviewFilterFooter" justifyContent="End" alignItems="Center" width="100%">
                    <Button text="초기화" type="Transparent" press=".onMmPurchasingFilterReset" class="nxMmOverviewFilterResetBtn" />
                    <Button text="조회" type="Emphasized" press=".onMmPurchasingFilterSearch" class="nxMmOverviewFilterSearchBtn" />
                </HBox>
            </VBox>
        </content>
    </Popover>

    <Popover
        id="mmGoodsMovementFilterPopover"
        placement="Bottom"
        contentWidth="30rem"
        showHeader="false"
        class="nxHeaderPopover nxMmOverviewFilterPopover nxMmGoodsMovementFilterPopover">
        <content>
            <VBox width="100%" class="nxPopoverBody nxMmOverviewFilterBody" renderType="Bare">
                <VBox class="nxHeaderPopoverTitleRow nxMmOverviewFilterHeader">
                    <Title text="조회 조건" level="H5" class="nxHeaderPopoverTitle" />
                    <Text text="Goods Movement MIGO/PO/자재 조회 기준을 설정합니다." class="nxMmOverviewFilterSubtitle" />
                </VBox>

                <VBox width="100%" class="nxMmOverviewFilterForm">
                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="MIGO 전표번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmGoodsMovement/migoSearch}"
                            placeholder="POMigoDoc / ProdMigoDoc"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="PO 번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmGoodsMovement/poSearch}"
                            placeholder="PurchaseOrder"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="자재번호 검색" class="nxMmOverviewFieldLabel" />
                        <SearchField
                            value="{dashboard>/mmGoodsMovement/materialSearch}"
                            placeholder="Material"
                            width="100%" />
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <Label text="MIGO Linked 여부" class="nxMmOverviewFieldLabel" />
                        <Select
                            selectedKey="{dashboard>/mmGoodsMovement/migoLinkedFilter}"
                            forceSelection="true"
                            width="100%"
                            items="{dashboard>/mmGoodsMovement/linkFilterOptions}">
                            <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                        </Select>
                    </VBox>

                    <VBox width="100%" class="nxMmOverviewFilterFieldGroup">
                        <CheckBox
                            text="부족 자재만 보기"
                            selected="{dashboard>/mmGoodsMovement/shortageOnly}" />
                    </VBox>
                </VBox>

                <HBox class="nxPopoverFooter nxMmOverviewFilterFooter" justifyContent="End" alignItems="Center" width="100%">
                    <Button text="초기화" type="Transparent" press=".onMmGoodsMovementFilterReset" class="nxMmOverviewFilterResetBtn" />
                    <Button text="조회" type="Emphasized" press=".onMmGoodsMovementFilterSearch" class="nxMmOverviewFilterSearchBtn" />
                </HBox>
            </VBox>
        </content>
    </Popover>
</mvc:View>
