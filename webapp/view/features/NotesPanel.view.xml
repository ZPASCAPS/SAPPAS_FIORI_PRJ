<!--
  NotesPanel.view.xml — 헤더 메모장 오버레이 (Pastell AI 패널 스타일)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.NotesPanel"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    height="100%"
    width="100%">

    <VBox
        id="notesPanel"
        visible="false"
        class="nxNotesPanel nxNotesPanelBox"
        width="48rem"
        height="38rem">
        <HBox
            id="notesPanelHeader"
            class="nxNotesPanelHeader"
            alignItems="Center"
            justifyContent="SpaceBetween"
            width="100%">
            <HBox alignItems="Center" class="nxNotesPanelHeaderText">
                <core:Icon src="sap-icon://notes" size="1.1rem" color="#0D9488" class="sapUiTinyMarginEnd" />
                <Title text="메모장" level="H5" class="nxNotesPanelTitle" />
                <Text text="드래그하여 이동" class="nxNotesPanelHeaderHint" />
            </HBox>
            <Button
                icon="sap-icon://decline"
                type="Transparent"
                tooltip="닫기"
                press=".onCloseNotesPanel"
                class="nxNotesPanelClose sapUiTinyMarginEnd" />
        </HBox>

        <VBox class="nxNotesPanelBody" width="100%" height="100%">
            <mvc:XMLView
                viewName="com.capstone.dashboard.fioridashboard.view.features.mm.MmNotes"
                width="100%"
                height="100%" />
        </VBox>
    </VBox>
</mvc:View>
