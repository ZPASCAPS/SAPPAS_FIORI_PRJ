<!--
  FiNote.view.xml — FI Note (저장 기능 미연결 시 안내 문구만 표시)
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.FiNote"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    width="100%">

    <VBox class="nxFiNote fiCockpitPage fiNotePage" width="100%" renderType="Bare" alignItems="Center">
        <VBox class="fiFeatureHero fiHeroNote fiHeroCard fiNoteHero" width="100%">
            <VBox class="fiHeroContent">
                <Title text="Note" level="H2" class="fiHeroTitle" />
                <Text
                    text="FI 업무 관련 참고사항과 확인 메모를 정리하는 화면입니다."
                    class="fiHeroDescription" />
            </VBox>
        </VBox>

        <VBox class="nxFiCard nxFiNoteCard" width="100%">
            <HBox alignItems="Center" class="nxFiNoteCardHead">
                <core:Icon src="sap-icon://notes" size="1.35rem" color="#0F766E" class="sapUiSmallMarginEnd" />
                <Title text="{dashboard>/fiNote/introTitle}" level="H4" />
            </HBox>
            <VBox class="fiNoteBody" alignItems="Center" justifyContent="Center">
                <core:Icon src="sap-icon://write-new-document" size="2.5rem" color="#94A3B8" class="sapUiMediumMarginBottom" />
                <Text text="{dashboard>/fiNote/introMessage}" class="fiNoteIntro" />
                <Text text="{dashboard>/fiNote/hint}" class="fiEmptyStateHint sapUiSmallMarginTop" />
            </VBox>
        </VBox>
    </VBox>
</mvc:View>
