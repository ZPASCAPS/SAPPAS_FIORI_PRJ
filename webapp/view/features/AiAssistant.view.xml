<!--
  AiAssistant.view.xml

  View: com.capstone.dashboard.fioridashboard.view.features.AiAssistant
  Controller: com.capstone.dashboard.fioridashboard.controller.features.AiAssistant

  역할:
  - 오른쪽 하단 플로팅 AI 챗봇 버튼과 대화 Dialog UI.

  대시보드 구조:
  DashboardMain → AiAssistant (화면 위 오버레이, nxOverlaySlot)

  협업:
  - 챗봇 UI·Dialog → 이 View
  - 열기/닫기 이벤트 → AiAssistant.controller.js
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.AiAssistant"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Button
        id="chatbotFloatingBtn"
        icon="sap-icon://comment"
        type="Emphasized"
        press=".onOpenChatbot"
        class="myFloatingButton" />

    <Dialog
        id="chatbotDialog"
        title="SAPPAS 챗봇 비서 🤖"
        draggable="true"
        resizable="true"
        contentWidth="350px"
        contentHeight="500px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="안녕하세요! 무엇을 도와드릴까요?" />
            </VBox>
        </content>
        <buttons>
            <Button text="닫기" press=".onCloseChatbot" />
        </buttons>
    </Dialog>
</mvc:View>
