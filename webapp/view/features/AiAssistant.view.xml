<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.features.AiAssistant"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Button
        id="chatbotFloatingBtn"
        icon="sap-icon://comment"
        type="Emphasized"
        press=".onOpenChatbot"
        class="myFloatingButton" />

    <Dialog
        id="chatbotDialog"
        title="SAPPAS 챗봇 비서 🤖"
        draggable="true"
        resizable="true"
        contentWidth="350px"
        contentHeight="500px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="안녕하세요! 무엇을 도와드릴까요?" />
            </VBox>
        </content>
        <buttons>
            <Button text="닫기" press=".onCloseChatbot" />
        </buttons>
    </Dialog>
</mvc:View>
