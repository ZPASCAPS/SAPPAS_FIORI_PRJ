<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    displayBlock="true"
    height="100%">

    <Page
        id="inventoryPage"
        showHeader="false"
        enableScrolling="false"
        class="invPage">

        <customHeader>
            <Bar class="invShellBar">
                <contentLeft>
                    <Title text="SANCAK" class="invBrand" />
                </contentLeft>
                <contentMiddle>
                    <SegmentedButton
                        id="navTabs"
                        selectedKey="{dashboard>/ui/navKey}"
                        selectionChange=".onNavChange"
                        class="invNavTabs">
                        <items>
                            <SegmentedButtonItem key="DASHBOARD" text="대시보드" />
                            <SegmentedButtonItem key="INVENTORY" text="재고목록" />
                        </items>
                    </SegmentedButton>
                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://action-settings" type="Transparent" tooltip="설정" />
                    <Button icon="sap-icon://bell" type="Transparent" tooltip="알림" />
                    <Button icon="sap-icon://refresh" type="Transparent" tooltip="새로고침" press=".onRefresh" />
                    <Avatar displaySize="XS" initials="DU" backgroundColor="Accent6" class="invAvatar" />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <HBox class="invWorkspace" renderType="Bare" height="100%" width="100%">

                <!-- 좌측 필터 -->
                <VBox class="invSideFrame" width="20rem">
                    <Toolbar class="invSideToolbar">
                        <Title text="필터" level="H3" titleStyle="H3" />
                        <ToolbarSpacer />
                        <ObjectStatus
                            text="{dashboard>/summary/totalLabel}"
                            state="Information"
                            class="invTotalPill" />
                    </Toolbar>

                    <ScrollContainer height="100%" vertical="true" horizontal="false" class="invSideScroll">
                        <VBox class="invSideContent">

                            <Label text="자재 상태" class="invSectionLabel" design="Bold" />
                            <layout:Grid
                                defaultSpan="L6 M6 S6"
                                hSpacing="0.5"
                                vSpacing="0.5"
                                class="invKpiGrid">
                                <GenericTile
                                    id="statAll"
                                    header="전체"
                                    frameType="OneByOne"
                                    class="invKpiTile invKpiTileAll"
                                    press=".onStatusFilter">
                                    <TileContent>
                                        <NumericContent
                                            value="{dashboard>/counts/all}"
                                            icon="sap-icon://bbyd-dashboard"
                                            valueColor="Neutral"
                                            withMargin="false"
                                            scale="건" />
                                    </TileContent>
                                    <customData>
                                        <core:CustomData key="filterKey" value="ALL" />
                                    </customData>
                                </GenericTile>
                                <GenericTile
                                    id="statOk"
                                    header="정상"
                                    frameType="OneByOne"
                                    class="invKpiTile invKpiTileOk"
                                    press=".onStatusFilter">
                                    <TileContent>
                                        <NumericContent
                                            value="{dashboard>/counts/active}"
                                            icon="sap-icon://accept"
                                            valueColor="Good"
                                            withMargin="false"
                                            scale="건" />
                                    </TileContent>
                                    <customData>
                                        <core:CustomData key="filterKey" value="OK" />
                                    </customData>
                                </GenericTile>
                                <GenericTile
                                    id="statWarn"
                                    header="확인"
                                    frameType="OneByOne"
                                    class="invKpiTile invKpiTileWarn"
                                    press=".onStatusFilter">
                                    <TileContent>
                                        <NumericContent
                                            value="{dashboard>/counts/warning}"
                                            icon="sap-icon://alert"
                                            valueColor="Critical"
                                            withMargin="false"
                                            scale="건" />
                                    </TileContent>
                                    <customData>
                                        <core:CustomData key="filterKey" value="WARN" />
                                    </customData>
                                </GenericTile>
                                <GenericTile
                                    id="statShort"
                                    header="부족"
                                    frameType="OneByOne"
                                    class="invKpiTile invKpiTileShort"
                                    press=".onStatusFilter">
                                    <TileContent>
                                        <NumericContent
                                            value="{dashboard>/counts/shortage}"
                                            icon="sap-icon://error"
                                            valueColor="Error"
                                            withMargin="false"
                                            scale="건" />
                                    </TileContent>
                                    <customData>
                                        <core:CustomData key="filterKey" value="SHORT" />
                                    </customData>
                                </GenericTile>
                            </layout:Grid>

                            <VBox class="invFilterBox">
                                <Label text="정렬" class="invFieldLabel" />
                                <Select selectedKey="{dashboard>/filters/sort}" change=".onSortChange" width="100%">
                                    <core:Item key="NAME_ASC" text="이름 A-Z" />
                                    <core:Item key="NAME_DESC" text="이름 Z-A" />
                                    <core:Item key="STOCK_ASC" text="재고 낮은순" />
                                    <core:Item key="STOCK_DESC" text="재고 높은순" />
                                </Select>
                                <Label text="재고" class="invFieldLabel" />
                                <Select selectedKey="{dashboard>/filters/stock}" change=".onStockFilterChange" width="100%">
                                    <core:Item key="ALL" text="전체" />
                                    <core:Item key="LOW" text="부족" />
                                    <core:Item key="OK" text="충분" />
                                </Select>
                                <Label text="카테고리" class="invFieldLabel" />
                                <Select
                                    id="categoryFilter"
                                    selectedKey="{dashboard>/filters/category}"
                                    change=".onCategoryChange"
                                    width="100%"
                                    items="{dashboard>/categories}">
                                    <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                                </Select>
                                <Label text="위치" class="invFieldLabel" />
                                <Select
                                    id="locationFilter"
                                    selectedKey="{dashboard>/filters/location}"
                                    change=".onLocationChange"
                                    width="100%"
                                    items="{dashboard>/locations}">
                                    <core:Item key="{dashboard>key}" text="{dashboard>text}" />
                                </Select>
                            </VBox>

                            <Button
                                text="초기화"
                                icon="sap-icon://refresh"
                                type="Transparent"
                                class="invClearBtn"
                                press=".onClearFilters" />
                        </VBox>
                    </ScrollContainer>
                </VBox>

                <!-- 우측 메인 -->
                <VBox class="invMainArea" height="100%" width="100%">

                    <HBox class="invToolbarFrame" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox alignItems="Center" class="invTitleGroup">
                            <Title text="자재" level="H2" />
                            <ObjectStatus
                                text="{dashboard>/summary/totalBadge}"
                                state="Information"
                                class="invPillBadge sapUiSmallMarginBegin" />
                        </HBox>
                        <HBox alignItems="Center" class="invToolbarActions">
                            <HBox class="invSearchFrame" alignItems="Center">
                                <SearchField
                                    id="materialSearch"
                                    width="22rem"
                                    placeholder="자재코드/이름 검색"
                                    search=".onSearch"
                                    liveChange=".onSearch" />
                                <Button icon="sap-icon://bar-code" type="Transparent" tooltip="스캔" />
                            </HBox>
                            <SegmentedButton selectedKey="LIST" class="invViewToggle">
                                <items>
                                    <SegmentedButtonItem key="LIST" icon="sap-icon://list" />
                                    <SegmentedButtonItem key="GRID" icon="sap-icon://grid" />
                                </items>
                            </SegmentedButton>
                            <Button icon="sap-icon://overflow" type="Transparent" />
                            <Button text="자재 추가" type="Emphasized" class="invPrimaryBtn" press=".onAddMaterial" />
                        </HBox>
                    </HBox>

                    <ScrollContainer
                        id="listScroll"
                        vertical="true"
                        horizontal="false"
                        class="invListScroll">
                        <layoutData>
                            <FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%" />
                        </layoutData>
                        <List
                            id="materialList"
                            class="invMaterialList"
                            items="{dashboard>/displayItems}"
                            growing="true"
                            growingThreshold="20"
                            noDataText="표시할 자재가 없습니다.">
                            <CustomListItem type="Inactive" class="invMaterialCard">
                                <HBox class="invCardInner" alignItems="Center" justifyContent="SpaceBetween">
                                    <HBox class="invCardLeft" alignItems="Center">
                                        <VBox class="invThumbFrame">
                                            <Image
                                                src="{dashboard>ImageUrl}"
                                                mode="Background"
                                                backgroundPosition="center center"
                                                backgroundSize="cover"
                                                class="invMaterialImg"
                                                visible="{= !!${dashboard>ImageUrl}}" />
                                            <core:Icon
                                                src="{dashboard>Icon}"
                                                size="1.75rem"
                                                color="#6b7280"
                                                visible="{= !${dashboard>ImageUrl}}"
                                                class="invThumbFallback" />
                                        </VBox>
                                        <VBox class="invCardInfo">
                                            <HBox alignItems="Center">
                                                <Title text="{dashboard>MaterialName}" level="H4" />
                                                <core:Icon
                                                    src="sap-icon://circle-task-2"
                                                    size="0.5rem"
                                                    color="#dc2626"
                                                    visible="{dashboard>IsLowStock}"
                                                    class="sapUiTinyMarginBegin" />
                                            </HBox>
                                            <Text text="{dashboard>CategoryLine}" class="invMutedText" />
                                            <Text text="{dashboard>MaterialCode}" class="invCodeText" />
                                        </VBox>
                                    </HBox>
                                    <HBox class="invCardMeta" alignItems="Center">
                                        <VBox class="invMetaCol">
                                            <Label text="비고" class="invMetaLabel" />
                                            <Text text="{dashboard>DateText}" />
                                        </VBox>
                                        <VBox class="invMetaCol invMetaColDivider">
                                            <Label text="저장위치" class="invMetaLabel" />
                                            <Text text="{dashboard>LocationText}" />
                                        </VBox>
                                        <ObjectStatus
                                            text="{dashboard>StatusText}"
                                            state="{dashboard>StatusState}"
                                            class="invStatusBadge" />
                                        <Button icon="sap-icon://overflow" type="Transparent" />
                                    </HBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </ScrollContainer>
                </VBox>
            </HBox>
        </content>
    </Page>
</mvc:View>
