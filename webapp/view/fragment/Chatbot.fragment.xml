<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="chatbotDialog"
        title="SAPPAS 챗봇 비서 🤖"
        draggable="true" 
        resizable="true"
        contentWidth="350px"
        contentHeight="500px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="안녕하세요! 무엇을 도와드릴까요?" />
            </VBox>
        </content>
        <buttons>
            <Button text="닫기" press=".onCloseChatbot" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>