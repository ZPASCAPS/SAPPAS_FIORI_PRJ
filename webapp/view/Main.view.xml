<!--
  Main.view.xml

  View: com.capstone.dashboard.fioridashboard.view.Main
  Controller: com.capstone.dashboard.fioridashboard.controller.Main

  역할:
  - 통합 대시보드 최상위 뼈대. 전체 너비 메인 영역만 배치한다.
  - 공통 dashboard JSONModel 초기화·SAP OData 로딩은 Main.controller.js가 담당한다.

  대시보드 구조:
  Main.view.xml
  └─ DashboardMain.view.xml   (전체 너비)

  협업:
  - 레이아웃 변경 시 이 파일만 수정한다.
  - 기능 UI·로직은 features/ 하위 View·Controller에서 작업한다.
-->
<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true"
    height="100%">

    <Page id="dashboardPage" showHeader="false" enableScrolling="false" class="nxPage">
        <content>
            <HBox class="nxShell" renderType="Bare" height="100%" width="100%">
                <mvc:XMLView
                    width="100%"
                    height="100%"
                    viewName="com.capstone.dashboard.fioridashboard.view.features.DashboardMain" />
            </HBox>
        </content>
    </Page>
</mvc:View>
