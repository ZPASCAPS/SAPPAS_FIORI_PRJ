<mvc:View
    controllerName="com.capstone.dashboard.fioridashboard.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true"
    height="100%">

    <Page id="dashboardPage" showHeader="false" enableScrolling="false" class="nxPage">
        <content>
            <HBox class="nxShell" renderType="Bare" height="100%" width="100%">

                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.ModuleSideNav" />

                <VBox class="nxMain" height="100%" width="100%">
                    <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.DashboardHeader" />

                    <ScrollContainer vertical="true" horizontal="false" class="nxContentScroll">
                        <VBox class="nxContent">
                            <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.DashboardToolbar" />
                            <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.InventoryStatus" />

                            <HBox class="nxRow2" renderType="Bare">
                                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.OrderImpact" />
                                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.StockActivity" />
                            </HBox>

                            <HBox class="nxRow3" renderType="Bare">
                                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.ProcessFlow" />
                                <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.MaterialShortage" />
                            </HBox>

                            <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.StatusSummary" />
                        </VBox>
                    </ScrollContainer>
                </VBox>
            </HBox>
        </content>
    </Page>

    <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.AiAssistant" />
    <mvc:XMLView viewName="com.capstone.dashboard.fioridashboard.view.features.MaterialCreate" />
</mvc:View>
